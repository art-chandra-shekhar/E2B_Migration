2611      PROCEDURE p_mg_case_notes_attach (
2612          src_case_num IN VARCHAR2,
2613          pi_tcase_id  IN NUMBER
2614      ) IS
2615      BEGIN
2616          INSERT /*+APPEND*/ INTO tcase_notes_attach
2617              SELECT
2618                  pi_tcase_id,
2619                  pkg_mg_util.f_mg_seq_num('CASE_NOTES_ATTACH', 'SEQ_NUM'),
2620                  1,
2621                  (
2622                      SELECT
2623                          classification_id
2624                      FROM
2625                          tlm_classification tlc
2626                      WHERE
2627                              tlc.classification = 'Legacy Sebela Attachments'
2628                          AND deleted IS NULL
2629                  )                                 classification,
2630                  sysdate,
2631                  1,
2632                  NULL,
2633                  dbms_lob.getlength(rsm.file_data) blobsize,
2634                  (
2635                      SELECT
2636                          nvl(max(sort_id) + 1,
2637                              1)
2638                      FROM
2639                          tcase_notes_attach
2640                      WHERE
2641                          case_id = pi_tcase_id
2642                  )                                 sort_id,
2643                  rsm.file_name,
2644                  NULL,
2645                  NULL,
2646                  NULL,
2647                  NULL,
2648                  rsm.file_data,
2649                  NULL,
2650                  NULL,
2651                  NULL,
2652                  NULL,
2653                  NULL,
2654                  'Legacy Sebela Attachments',
2655                  NULL,
2656                  5,
2657                  NULL
2658              FROM
2659                  mg_case_addn_attachments rsm
2660              WHERE
2661                  upper(trim(rsm.case_num)) = upper(trim(src_case_num));
2662  
2663      EXCEPTION
