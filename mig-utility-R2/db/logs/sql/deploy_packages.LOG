111      PROCEDURE p_mg_case_study (
112          src_case_num IN VARCHAR2,
113          pi_tcase_id  IN NUMBER
114      ) IS
115  
116          CURSOR c_case_study IS
117          SELECT
118              case_number,
119              studyname,
120              sponsorstudynumb,
121              observestudytype
122          FROM
123              s_primarysource
124          WHERE
125              studyname
126              || sponsorstudynumb
127              || observestudytype IS NOT NULL
128              AND case_number = src_case_num;
129  
130          v_index      PLS_INTEGER := 0;
131          TYPE v_case_study_tab IS
132              TABLE OF tcase_study%rowtype INDEX BY PLS_INTEGER;
133          v_case_study v_case_study_tab;
134          V_BLINDED_PROD_PRESENT NUMBER;
135      BEGIN
136  
137  SELECT COUNT(1)
138  INTO V_BLINDED_PROD_PRESENT
139  FROM S_DRUG
140  WHERE UPPER(MEDICINALPRODUCT) LIKE '%BLIND%' 
141  AND CASE_NUMber=SRC_CASE_NUM;
142  
143          FOR v_row IN c_case_study LOOP
144              v_index := v_index + 1;
145              --fetch study key and cohirt id from mg)_study prduct mapping
146            --  if comPAny study then study key is not null then
147            --cohort_id=msp.cohort_id.
148             --     fetch these from  config
149              v_case_study(v_index).case_id := pi_tcase_id;
150              pkg_mg_buss_rules.p_mg_study_mapping(v_row.studyname,
151                                                   v_row.sponsorstudynumb,
152                                                   v_row.observestudytype,
153                                                   v_case_study(v_index).cohort_id,
154                                                   v_case_study(v_index).study_key,
155                                                   v_case_study(v_index).blind_name,
156                                                   v_case_study(v_index).blind_name_j,
157                                                   v_case_study(v_index).study_type,
158                                                   v_case_study(v_index).study_num,
159                                                   v_case_study(v_index).study_num_j,
160                                                   v_case_study(v_index).protocol_num,
161                                                   v_case_study(v_index).classification_id,
162                                                   v_case_study(v_index).protocol_id,
163                                                   v_case_study(v_index).study_desc,
164                                                   v_case_study(v_index).study_desc_j,
165                                                   v_case_study(v_index).dev_phase_id);
166  
167                                             IF  v_case_study(v_index).study_key IS NULL THEN
168                                               v_case_study(v_index).study_num:=V_ROW.studyname;
169                                               v_case_study(v_index).study_desc:=V_ROW.sponsorstudynumb;
170                                                        v_case_study(v_index).study_type:=V_ROW.observestudytype;
171                                                        END IF;
172  
173              v_case_study(v_index).product_count := 0;--CONFIRM THIS--this will be reset in case_product 
174          /*LEFT COLUMNS CANNOT BE PULLED FROM CONFIG*/
175              v_case_study(v_index).center_id := NULL;
176              v_case_study(v_index).center_name := NULL;
177              v_case_study(v_index).other_id := NULL;
178  
179  
180              IF v_case_study(v_index).study_type=3 THEN
181              v_case_study(v_index).code_broken := 4;--open label study for now
182  
183              ELSIF v_case_study(v_index).study_type IN (1,2) THEN
184             IF V_BLINDED_PROD_PRESENT>0 THEN 
185             v_case_study(v_index).code_broken:=0;
186             ELSE
187             v_case_study(v_index).code_broken:=3;
188             END IF;
189              END IF;
190              v_case_study(v_index).broken_by := NULL;--MIGRATION USER
191              v_case_study(v_index).broken_date := NULL;
192              v_case_study(v_index).reason := NULL;
193              v_case_study(v_index).week := NULL;
194              v_case_study(v_index).visit := NULL;
195              v_case_study(v_index).center_name_j := NULL;
196              v_case_study(v_index).clin_compound_num_j := NULL;
197              v_case_study(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
198          END LOOP;
199  
200          IF v_index = 0 THEN
201              v_index := v_index + 1;
202              v_case_study(v_index).case_id := pi_tcase_id;
203              v_case_study(v_index).product_count := 0;
204                 v_case_study(v_index).code_broken:=-1;
205                 v_case_study(v_index).study_type:=-1;
206              v_case_study(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
207          END IF;
208  
209  --        pkg_mg_util.g_study_key := v_case_study(v_index).study_key;
210          FOR i IN 1..v_index LOOP
211              INSERT INTO tcase_study VALUES v_case_study ( i );
212  
213          END LOOP;
214  
215      EXCEPTION
216          WHEN OTHERS THEN
217              pkg_mg_util.p_mg_log_message(
218                  pi_scase_num    => src_case_num,
219                  pi_tcase_id     => pi_tcase_id,
220                  pi_message_type => 'ERROR',
221                  pi_message      => 'P_MG_CASE_STUDY ' || dbms_utility.format_error_stack,
222                  pi_thread_id    => NULL,
223                  pi_date_time    => systimestamp
224              );
225  
226              raise_application_error(-20001, sqlerrm);
227      END p_mg_case_study;
