350      FUNCTION f_fetch_seq_map_val (
351          pi_stable_name IN VARCHAR2,
352          pi_ttable_name IN VARCHAR2,
353          pi_scol_name   IN VARCHAR2,
354          pi_tcol_name   IN VARCHAR2,
355          pi_seq_num     IN NUMBER,
356          pi_seq_type    IN VARCHAR2
357      ) RETURN NUMBER IS
358          v_seq NUMBER := 0;
359      BEGIN
360          IF pi_seq_num IS NULL THEN
361              RETURN NULL;
362          END IF;
363          v_seq := NULL;
364          IF pi_seq_type = 'S' THEN
365              SELECT
366                  sseq
367              INTO v_seq
368              FROM
369                  mg_st_sequence_map m
370              WHERE
371                      m.scase_num = pkg_mg_util.g_scase_num
372                  AND m.tcaseid = pkg_mg_util.g_tcase_id
373                  AND m.stablename = pi_stable_name
374                  AND m.ttablename = pi_ttable_name
375                  AND m.scolname = pi_scol_name
376                  AND m.tcolname = pi_tcol_name
377                  AND m.tseq = pi_seq_num;
378  
379          ELSIF pi_seq_type = 'T' THEN
380              SELECT
381                  tseq
382              INTO v_seq
383              FROM
384                  mg_st_sequence_map m
385              WHERE
386                      m.scase_num = pkg_mg_util.g_scase_num
387                  AND m.tcaseid = pkg_mg_util.g_tcase_id
388                  AND m.stablename = pi_stable_name
389                  AND m.ttablename = pi_ttable_name
390                  AND m.scolname = pi_scol_name
391                  AND m.tcolname = pi_tcol_name
392                  AND m.sseq = pi_seq_num;
393  
394          END IF;
395  
396          RETURN v_seq;
397      EXCEPTION
398          WHEN no_data_found THEN
399              pkg_mg_util.p_mg_log_message(
400                  pi_scase_num    => g_scase_num,
401                  pi_tcase_id     => g_tcase_id,
402                  pi_message_type => 'WARNING',
403                  pi_message      => 'Sequence Mapping Not Found: '
404                                || pkg_mg_util.g_tcase_id
405                                || ' and Table: '
406                                || pi_ttable_name
407                                || '; Value: '
408                                || pi_seq_num,
409                  pi_thread_id    => NULL,
410                  pi_date_time    => systimestamp
411              );
412  
413              RETURN NULL;
414          WHEN too_many_rows THEN
415                pkg_mg_util.p_mg_log_message(
416                  pi_scase_num    => g_scase_num,
417                  pi_tcase_id     => g_tcase_id,
418                  pi_message_type => 'WARNING',
419                  pi_message      => 'Multiple Sequence Mapping Found: '
420                                || pkg_mg_util.g_tcase_id
421                                || ' and Table: '
422                                || pi_ttable_name
423                                || '; Value: '
424                                || pi_seq_num,
425                  pi_thread_id    => NULL,
426                  pi_date_time    => systimestamp
427              );
428            return null;
429              WHEN others THEN
430               pkg_mg_util.p_mg_log_message(
431                  pi_scase_num    => g_scase_num,
432                  pi_tcase_id     => g_tcase_id,
433                  pi_message_type => 'ERROR',
434                  pi_message      => 'ERROR OCCURED IN f_fetch_seq_map_val For case_id: '
435                                || pkg_mg_util.g_tcase_id
436                                || ' and Table: '
437                                || pi_ttable_name
438                                || '; Value: '
439                                || pi_seq_num,
440                  pi_thread_id    => NULL,
441                  pi_date_time    => systimestamp
442              );
443      END f_fetch_seq_map_val;
