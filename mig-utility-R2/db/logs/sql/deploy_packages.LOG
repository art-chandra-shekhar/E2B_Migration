1927      PROCEDURE p_mg_case_prod_indications (
1928          src_case_num IN VARCHAR2,
1929          pi_tcase_id  IN NUMBER
1930      ) IS
1931  
1932          CURSOR c_case_prod_indications IS
1933          SELECT
1934              *
1935          FROM
1936              s_drug sd
1937              where sd.drug_seq_num=sd.drug_seq_num
1938              and sd.case_number=src_case_num;
1939  
1940          v_index                 PLS_INTEGER := 0;
1941          TYPE v_case_prod_indications_tab IS
1942              TABLE OF tcase_prod_indications%rowtype INDEX BY PLS_INTEGER;
1943          v_case_prod_indications v_case_prod_indications_tab;
1944      BEGIN
1945          FOR v_row IN c_case_prod_indications LOOP
1946              v_index := v_index + 1;
1947              v_case_prod_indications(v_index).case_id := pi_tcase_id;
1948              v_case_prod_indications(v_index).prod_seq_num := pkg_mg_util.f_fetch_seq_map_val('S_DRUG', 'CASE_PRODUCT', 'DRUG_SEQ_NUM', 'SEQ_NUM', V_ROW.DRUG_SEQ_NUM,
1949                                                'T');
1950              v_case_prod_indications(v_index).seq_num :=  pkg_mg_util.f_mg_seq_num('CASE_PROD_INDICATIONS', 'SEQ_NUM');
1951              v_case_prod_indications(v_index).IND_REPTD := V_ROW.DRUGINDICATION;
1952                 v_case_prod_indications(v_index).IND_CODED := V_ROW.DRUGINDICATION;
1953              v_case_prod_indications(v_index).sort_id := V_INDEX;
1954              v_case_prod_indications(v_index).ind_code := V_ROW.DRUGINDICATION;
1955              v_case_prod_indications(v_index).ind_pref_term := V_ROW.DRUGINDICATION;
1956              v_case_prod_indications(v_index).enterprise_id :=  pkg_mg_util.f_mg_key_val('Enterprise Id');
1957              v_case_prod_indications(v_index).multi_event_exists := NULL;
1958  
1959                pkg_mg_buss_rules.p_meddra_map_br001('Product Indication',
1960  
1961                                                   v_row.DRUGINDICATION,
1962  
1963                                                   v_row.DRUGINDICATION,
1964                                                  v_row.DRUGINDICATION,
1965                                                   v_case_prod_indications(v_index).ind_llt_code,
1966                                                   v_case_prod_indications(v_index).ind_llt,
1967                                                   v_case_prod_indications(v_index).ind_code,
1968                                                   v_case_prod_indications(v_index).ind_pref_term,
1969                                                   v_case_prod_indications(v_index).ind_hlt_code,
1970                                                   v_case_prod_indications(v_index).ind_hlt,
1971                                                   v_case_prod_indications(v_index).ind_hlgt_code,
1972                                                   v_case_prod_indications(v_index).ind_hlgt,
1973                                                   v_case_prod_indications(v_index).ind_soc_code,
1974                                                   v_case_prod_indications(v_index).ind_soc,
1975                                                   v_case_prod_indications(v_index).ind_code_status,
1976                                                   v_case_prod_indications(v_index).ind_code_dict);
1977          END LOOP;
1978  
1979          FOR i IN 1..v_index LOOP
1980              INSERT INTO tcase_prod_indications VALUES v_case_prod_indications ( i );
1981  
1982          END LOOP;
1983  
1984      EXCEPTION
1985          WHEN OTHERS THEN
1986              pkg_mg_util.p_mg_log_message(
1987                  pi_scase_num    => src_case_num,
1988                  pi_tcase_id     => pi_tcase_id,
1989                  pi_message_type => 'ERROR',
1990                  pi_message      => 'P_MG_CASE_PROD_INDICATIONS ' || dbms_utility.format_error_stack,
1991                  pi_thread_id    => NULL,
1992                  pi_date_time    => systimestamp
1993              );
1994  
1995              raise_application_error(-20001, sqlerrm);
1996      END p_mg_case_prod_indications;
