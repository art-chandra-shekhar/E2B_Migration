1264      PROCEDURE p_mg_case_hosp (
1265          src_case_num IN VARCHAR2,
1266          pi_tcase_id  IN NUMBER
1267      ) IS
1268  
1269          CURSOR c_case_hosp IS
1270          SELECT
1271              *
1272          FROM
1273              dual;
1274  
1275          v_index     PLS_INTEGER := 0;
1276          TYPE v_case_hosp_tab IS
1277              TABLE OF tcase_hosp%rowtype INDEX BY PLS_INTEGER;
1278          v_case_hosp v_case_hosp_tab;
1279      BEGIN
1280          FOR v_row IN c_case_hosp LOOP
1281              v_index := v_index + 1;
1282              v_case_hosp(v_index).case_id := pi_tcase_id;
1283              v_case_hosp(v_index).seq_num := pkg_mg_util.f_mg_seq_num('case_hosp', 'SEQ_NUM');
1284  --           
1285              v_case_hosp(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1286          END LOOP;
1287  
1288          FOR i IN 1..v_index LOOP
1289              INSERT INTO tcase_hosp VALUES v_case_hosp ( i );
1290  
1291          END LOOP;
1292  
1293      EXCEPTION
1294          WHEN OTHERS THEN
1295              pkg_mg_util.p_mg_log_message(
1296                  pi_scase_num    => src_case_num,
1297                  pi_tcase_id     => pi_tcase_id,
1298                  pi_message_type => 'ERROR',
1299                  pi_message      => 'P_MG_CASE_HOSP ' || dbms_utility.format_error_stack,
1300                  pi_thread_id    => NULL,
1301                  pi_date_time    => systimestamp
1302              );
1303  
1304              raise_application_error(-20001, sqlerrm);
1305      END p_mg_case_hosp;
