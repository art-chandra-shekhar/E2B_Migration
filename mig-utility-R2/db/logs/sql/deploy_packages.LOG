445      FUNCTION f_get_tgt_lic_id (
446          pi_s_trade_name  IN VARCHAR2,
447          pi_s_lic_num     IN VARCHAR2,
448          pi_s_lic_country IN VARCHAR2,
449          pi_prod_seq      NUMBER,
450          pi_event_seq     NUMBER,
451          pi_license_id    NUMBER
452      ) RETURN NUMBER IS
453  
454          t_lic_id    NUMBER := NULL;
455          v_s_country NUMBER := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Countries', pi_s_lic_country);
456      BEGIN
457          IF pi_s_trade_name IS NULL THEN
458              pkg_mg_util.p_mg_log_message(
459                  pi_scase_num    => g_scase_num,
