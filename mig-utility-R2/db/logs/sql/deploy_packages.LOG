1836      PROCEDURE p_mg_case_prod_ingredient (--TBD
1837          src_case_num IN VARCHAR2,
1838          pi_tcase_id  IN NUMBER
1839      ) IS
1840  
1841          CURSOR c_case_prod_ingredient_comp IS
1842          SELECT
1843              lpin.ingredient_id,
1844              lpro.conc_unit_id,
1845              lpro.concentration,
1846              cpro.product_id,
1847              cpro.pat_exposure,
1848              cpro.deleted,
1849              cpro.seq_num
1850          FROM
1851              tlm_product        lpro,
1852              tcase_product      cpro,
1853              tlm_pf_ingredients lpin
1854          WHERE
1855                  lpro.product_id = nvl(cpro.product_id, cpro.pat_exposure)
1856              AND nvl(cpro.product_id, cpro.pat_exposure) > 0
1857              AND lpin.family_id = lpro.family_id
1858              AND cpro.case_id = pi_tcase_id;
1859  
1860          CURSOR c_case_prod_ingredient_noncomp IS
1861          SELECT
1862              sd.case_number,
1863              activesubstancename,
1864              sd.drug_seq_num
1865          FROM
1866                   s_drug sd
1867              INNER JOIN s_activesubstance sas ON sas.case_number = sd.case_number
1868                                                    AND sd.drug_seq_num = sas.drug_seq
1869          WHERE
1870                  sd.drug_seq_num = sd.drug_seq_num
1871              AND sd.prod_seq_num IS NULL
1872              AND sd.case_number = src_case_num;
1873  
1874          v_index                PLS_INTEGER := 0;
1875          TYPE v_case_prod_ingredient_tab IS
1876              TABLE OF tcase_prod_ingredient%rowtype INDEX BY PLS_INTEGER;
1877          v_case_prod_ingredient v_case_prod_ingredient_tab;
1878      BEGIN
1879          FOR v_comp IN c_case_prod_ingredient_comp LOOP
1880              v_index := v_index + 1;
1881              v_case_prod_ingredient(v_index).case_id := pi_tcase_id;
1882              v_case_prod_ingredient(v_index).seq_num := v_comp.seq_num;
1883              v_case_prod_ingredient(v_index).item := pkg_mg_util.f_mg_seq_num('CASE_PROD_INGREDIENT', 'ITEM');--we do not have source item to map in mg_st_seq_map.not req as well?
1884              v_case_prod_ingredient(v_index).ingredient_id := v_comp.ingredient_id;
1885              v_case_prod_ingredient(v_index).conc_unit_id := v_comp.conc_unit_id;
1886              v_case_prod_ingredient(v_index).concentration := v_comp.concentration;
1887              v_case_prod_ingredient(v_index).deleted := NULL;
1888              v_case_prod_ingredient(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1889          END LOOP;
1890  
1891          FOR v_non_comp IN c_case_prod_ingredient_noncomp LOOP
1892              v_index := v_index + 1;
1893              v_case_prod_ingredient(v_index).case_id := pi_tcase_id;
1894              v_case_prod_ingredient(v_index).seq_num := pkg_mg_util.f_fetch_seq_map_val('S_DRUG', 'CASE_PRODUCT', 'DRUG_SEQ_NUM', 'SEQ_NUM'
1895              , v_non_comp.drug_seq_num,
1896                                                                                         'T');
1897  
1898              v_case_prod_ingredient(v_index).item := pkg_mg_util.f_mg_seq_num('CASE_PROD_INGREDIENT', 'ITEM');
1899              pkg_mg_buss_rules.p_tgt_ingredient_id(v_non_comp.activesubstancename,
1900                                                    v_case_prod_ingredient(v_index).ingredient_id);
1901  --            v_case_prod_ingredient(v_index).conc_unit_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Dose Units', v_non_comp.conc_units_id
1902  --            );
1903  
1904  --            v_case_prod_ingredient(v_index).concentration := v_non_comp.concentration;
1905              v_case_prod_ingredient(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1906          END LOOP;
1907  
1908          FOR i IN 1..v_index LOOP
1909              INSERT INTO tcase_prod_ingredient VALUES v_case_prod_ingredient ( i );
1910  
1911          END LOOP;
1912  
1913      EXCEPTION
1914          WHEN OTHERS THEN
1915              pkg_mg_util.p_mg_log_message(
1916                  pi_scase_num    => src_case_num,
1917                  pi_tcase_id     => pi_tcase_id,
1918                  pi_message_type => 'ERROR',
1919                  pi_message      => 'P_MG_CASE_INGREDIENT:' || dbms_utility.format_error_stack,
1920                  pi_thread_id    => NULL,
1921                  pi_date_time    => systimestamp
1922              );
1923  
1924              raise_application_error(-20001, sqlerrm);
1925      END p_mg_case_prod_ingredient;
