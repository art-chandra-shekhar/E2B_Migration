887  FUNCTION f_convert_to_seconds (
888      pi_duration        IN NUMBER,
889      pi_duration_unit   IN NUMBER
890  ) RETURN NUMBER
891  IS
892      v_seconds NUMBER;
893  BEGIN
894      v_seconds :=
895          CASE pi_duration_unit
896              WHEN 807 THEN pi_duration                                   -- Seconds
897              WHEN 806 THEN pi_duration * 60                              -- Minutes
898              WHEN 805 THEN pi_duration * 60 * 60                         -- Hours
899              WHEN 804 THEN pi_duration * 60 * 60 * 24                    -- Days
900              WHEN 803 THEN pi_duration * 60 * 60 * 24 * 7                -- Weeks
901              WHEN 802 THEN pi_duration * 60 * 60 * 24 * 30               -- Months (30 days approx)
902              WHEN 801 THEN pi_duration * 60 * 60 * 24 * 365              -- Years (approx)
903              ELSE NULL
904          END;
905  
906      RETURN v_seconds;
907  END f_convert_to_seconds;
908  
909      FUNCTION f_mg_VIEWS_AVAILABLE (
910          pi_product_id IN NUMBER
911      ) RETURN NUMBER IS
912          v_VIEWS_AVAILABLE NUMBER := 7;
913          v_lic_type  VARCHAR(1000) := NULL;
914      BEGIN
915          IF pi_product_id IS NULL THEN--non company product
916              RETURN v_VIEWS_AVAILABLE;
917          END IF;
918          SELECT
919              LISTAGG(DISTINCT upper(tlt.license_type),
920                               ',')
921          INTO v_lic_type
922          FROM
923                   tlm_lic_products tllp
924              INNER JOIN tlm_license       tll ON tllp.license_id = tll.license_id
925              INNER JOIN tlm_license_types tlt ON tll.license_type_id = tlt.license_type_id where tllp.product_id=pi_product_id;
926  IF    instr(v_lic_type, 'DRUG')    > 0
927    AND instr(v_lic_type, 'DEVICE')  > 0
928    AND instr(v_lic_type, 'VACCINE') > 0
929  THEN
930      v_VIEWS_AVAILABLE := 7;
931  
932  ELSIF instr(v_lic_type, 'DEVICE')  > 0
933    AND instr(v_lic_type, 'VACCINE') > 0
934  THEN
935      v_VIEWS_AVAILABLE := 6;
936  
937  ELSIF instr(v_lic_type, 'DRUG')    > 0
938    AND instr(v_lic_type, 'VACCINE') > 0
939  THEN
940      v_VIEWS_AVAILABLE := 5;
941  
942  ELSIF instr(v_lic_type, 'DRUG')    > 0
943    AND instr(v_lic_type, 'DEVICE')  > 0
944  THEN
945      v_VIEWS_AVAILABLE := 4;
946  
947  ELSIF instr(v_lic_type, 'VACCINE') > 0 THEN
948      v_VIEWS_AVAILABLE := 3;
949  
950  ELSIF instr(v_lic_type, 'DEVICE') > 0 THEN
951      v_VIEWS_AVAILABLE := 2;
952  
953  ELSIF instr(v_lic_type, 'DRUG') > 0 THEN
954      v_VIEWS_AVAILABLE := 1;
955  
956  END IF;
957  
958          RETURN v_VIEWS_AVAILABLE;
959      EXCEPTION
960          WHEN OTHERS THEN
961              pkg_mg_util.p_mg_log_message(
962                  pi_scase_num    => pkg_mg_util.g_scase_num,
963                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
964                  pi_message_type => 'ERROR',
965                  pi_message      => 'Error in function: F_MG_VIEWS_AVAILABLE' || sqlerrm,
966                  pi_thread_id    => NULL,
967                  pi_date_time    => systimestamp
968              );
969  
970              RETURN v_VIEWS_AVAILABLE;
971      END f_mg_VIEWS_AVAILABLE;
972  
973  END pkg_mg_util;

