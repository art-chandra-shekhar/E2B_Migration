3593      PROCEDURE p_mg_execution (
3594          pi_thread_id NUMBER,
3595          pi_scase_num VARCHAR2 DEFAULT NULL
3596      ) IS
3597  
3598          CURSOR case_cur IS
3599          SELECT
3600              *
3601          FROM
3602              mg_case_list
3603          WHERE
3604                  exec_thread_id = pi_thread_id
3605              AND scasenum = nvl(pi_scase_num, scasenum)
3606              AND status = 0;
3607  
3608          v_message         mg_case_error_log.message_type%TYPE;
3609          v_msg_cnt         NUMBER := 0;
3610          v_msg_cnt_e       NUMBER := 0;
3611          v_msg_cnt_w       NUMBER := 0;
3612          v_mig_status_code NUMBER := 0;
3613      BEGIN
3614          vpd_admin.pkg_rls.set_context('SYSTEM', 5, 'ARGUS_SAFETY');
3615          FOR r IN case_cur LOOP
3616              v_msg_cnt := 0;
3617              v_msg_cnt_e := 0;
3618              v_msg_cnt_w := 0;
3619              v_mig_status_code := 1;
3620              pkg_mg_util.g_scase_num := r.scasenum;
3621              pkg_mg_util.g_tcase_id := r.tcaseid;
3622              DELETE FROM mg_case_error_log
3623              WHERE
3624                  tcase_id = r.tcaseid;
3625  
3626              DELETE FROM mg_st_sequence_map
3627              WHERE
3628                  tcaseid = r.tcaseid;
3629  
3630              BEGIN
3631                  pkg_mg_migration.p_mg_case_master(r.scasenum, r.tcaseid);
3632                  pkg_mg_migration.p_mg_case_study(r.scasenum, r.tcaseid);
3633               --   pkg_mg_migration.p_mg_case_followup(r.scasenum, r.tcaseid);
3634                  pkg_mg_migration.p_mg_case_literature(r.scasenum, r.tcaseid);
3635           --       pkg_mg_migration.p_mg_case_classifications(r.scasenum, r.tcaseid);
3636                  pkg_mg_migration.p_mg_case_pat_info(r.scasenum, r.tcaseid);
3637                  pkg_mg_migration.p_mg_case_pat_hist(r.scasenum, r.tcaseid);
3638                  pkg_mg_migration.p_mg_case_lab_data(r.scasenum, r.tcaseid);
3639                  pkg_mg_migration.p_mg_case_pat_tests(r.scasenum, r.tcaseid);
3640             --     pkg_mg_migration.p_mg_case_parent_info(r.scasenum, r.tcaseid);
3641                --  pkg_mg_migration.p_mg_case_pat_race(r.scasenum, r.tcaseid);
3642                --  pkg_mg_migration.p_mg_case_pregnancy(r.scasenum, r.tcaseid);
3643                --  pkg_mg_migration.p_mg_case_neonates(r.scasenum, r.tcaseid);
3644                  pkg_mg_migration.p_mg_case_event(r.scasenum, r.tcaseid);
3645           --       pkg_mg_migration.p_mg_case_hosp(r.scasenum, r.tcaseid);
3646                  pkg_mg_migration.p_mg_case_product(r.scasenum, r.tcaseid);
3647                  --dbms_output.put_line('N');
3648                  pkg_mg_migration.p_mg_case_prod_ingredient(r.scasenum, r.tcaseid);
3649           pkg_mg_migration.p_mg_case_prod_indications(r.scasenum, r.tcaseid);
3650              --    pkg_mg_migration.p_mg_case_death(r.scasenum, r.tcaseid);
3651               --   pkg_mg_migration.p_mg_case_death_details(r.scasenum, r.tcaseid);
3652             --     pkg_mg_migration.p_mg_case_event_detail(r.scasenum, r.tcaseid);
3653                  pkg_mg_migration.p_mg_case_event_assess(r.scasenum, r.tcaseid);
3654                  pkg_mg_migration.p_mg_case_comments(r.scasenum, r.tcaseid);
3655                  pkg_mg_migration.p_mg_case_company_cmts(r.scasenum, r.tcaseid);
3656  --           pkg_mg_migration.p_mg_case_lock_info(r.scasenum, r.tcaseid);
3657               --   pkg_mg_migration.p_mg_case_justifications(r.scasenum, r.tcaseid);
