3582                  pi_message      => 'P_MG_AUDIT_LOG' || dbms_utility.format_error_stack,
3583                  pi_thread_id    => NULL,
3584                  pi_date_time    => systimestamp
3585              );
3586  
3587              raise_application_error(-20001, sqlerrm);
3588      END p_mg_Audit_log;
