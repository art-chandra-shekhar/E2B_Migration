217      PROCEDURE p_get_partial_date (
218          pi_table_name     IN VARCHAR2,
219          pi_date_format    IN NUMBER,
220          pi_date_in_number IN VARCHAR2,
221          po_date           OUT DATE,
222          po_date_res       OUT NUMBER,
223          po_date_partial   OUT VARCHAR2
224      ) AS
225          v_value VARCHAR2(50);
226      BEGIN
227          IF pi_date_in_number IS NULL THEN
228              po_date := NULL;
229              po_date_res := 0;
230              po_date_partial := NULL;
231              RETURN;
232          END IF;
233  
234  IF VALIDATE_CONVERSION((PI_DATE_IN_NUMBER) AS DATE,'DD-MM-RR') = 1 THEN--exception partial date mapping
235  
236     po_date := TO_DATE ( PI_DATE_IN_NUMBER, 'DD-MM-RR' );
237     po_date_res     := 5;
238     po_date_partial := PI_DATE_IN_NUMBER;
239     RETURN;
240  END IF;
241     v_value         := TRIM(TO_CHAR(PI_DATE_IN_NUMBER));
242      /*first use format if present*/
243          IF pi_date_format IS NOT NULL THEN
244              IF pi_date_format = 602 THEN
245                  po_date := TO_DATE ( v_value, 'YYYY' );
246                  po_date_res := 5;
247                  po_date_partial := to_char(po_date, 'YYYY');
248              ELSIF pi_date_format = 610 THEN
249                  po_date := TO_DATE ( v_value, 'YYYYMM' );
250                  po_date_res := 7;
251                  po_date_partial := to_char(po_date, 'MM-YYYY');
252              ELSIF pi_date_format = 102 THEN
253                  po_date := TO_DATE ( v_value, 'YYYYMMDD' );
254                  po_date_res := 8;
255                  po_date_partial := to_char(po_date, 'DD-MM-YYYY');
256              ELSIF pi_date_format = 203 THEN
257                  po_date := TO_DATE ( v_value, 'YYYYMMDDHH24MI' );
258                  po_date_res := 8;
259              ELSE
260                  po_date := NULL;
261                  po_date_res := 0;
262                  po_date_partial := NULL;
263              END IF;
264  
265   /*use length if format not present*/
266          ELSE
267              IF length(v_value) = 4 THEN
268                  po_date := TO_DATE ( v_value, 'YYYY' );
269                  po_date_res := 5;
270              ELSIF length(v_value) = 6 THEN
271                  po_date := TO_DATE ( v_value, 'YYYYMM' );
272                  po_date_res := 7;
273              ELSIF length(v_value) = 8 THEN
274                  po_date := TO_DATE ( v_value, 'YYYYMMDD' );
275                  po_date_res := 8;
276              ELSIF length(v_value) = 12 THEN
277                  po_date := TO_DATE ( v_value, 'YYYYMMDDHH24MI' );
278                  po_date_res := 8;
279              ELSE
280                  po_date := NULL;
281                  po_date_res := 0;
282                  po_date_partial := NULL;
283              END IF;
284          END IF;
285  
286          IF po_date IS NOT NULL THEN
287              po_date_partial := to_char(po_date, 'DD-MM-YYYY');
288          ELSE
289              po_date_partial := NULL;
290          END IF;
291  
292      EXCEPTION
293          WHEN OTHERS THEN
294              pkg_mg_util.p_mg_log_message(
295                  pi_scase_num    => pkg_mg_util.g_scase_num,
296                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
297                  pi_message_type => 'ERROR',
298                  pi_message      => 'Error: IN P_GET_PARTIAL_DATE Called from table'
299                                || pi_table_name
300                                || ':'
301                                || sqlerrm,
302                  pi_thread_id    => NULL,
303                  pi_date_time    => systimestamp
304              );
305      END p_get_partial_date;
306  
307      PROCEDURE p_get_tgt_prod_id (
308         PI_suspect_drug_name IN VARCHAR2,
309          PI_medicinalproduct IN VARCHAR2,
310           PI_drugdosageform IN VARCHAR2,
311            PI_drugauthorizationcountry IN VARCHAR2,
312             PI_drugauthorizationnumb IN VARCHAR2,
313              PI_suspect_product_generic_name IN VARCHAR2,
314          po_tgt_prod_id     OUT NUMBER,
315          po_tgt_prod_lic_id OUT NUMBER
316      ) IS
317      V_CNT NUMBER:=0;
318      v_drug_cnt NUMBER:=0;
319      BEGIN
320         po_tgt_prod_id := NULL;
321          po_tgt_prod_lic_id := NULL;      
322  
323  
324  
325    SELECT
326     TGT_PROD_ID,PROD_LIC_ID
327      INTO 
328      po_tgt_prod_id,
329      po_tgt_prod_lic_id
330  FROM
331      mg_product_mapping
332  WHERE
333      upper(trim(suspect_drug_name))
334      || upper(trim(medicinal_product))
335      || upper(trim(dosage_form))
336      || upper(trim(drug_auth_country))
337      || upper(trim(drug_auth_number))
338      || upper(trim(generic_name)) = upper(trim(PI_suspect_drug_name))
339                                     || upper(trim(PI_medicinalproduct))
340                                     || upper(trim(PI_drugdosageform))
341                                     || upper(trim(PI_drugauthorizationcountry))
342                                     || upper(trim(PI_drugauthorizationnumb))
343                                     || upper(trim(PI_suspect_product_generic_name));
344  
345  
346      EXCEPTION
347          WHEN no_data_found THEN  
348          begin
349  
350    SELECT
351     distinct TGT_PROD_ID,PROD_LIC_ID
352      INTO 
353      po_tgt_prod_id,
354      po_tgt_prod_lic_id
355  FROM
356      mg_product_mapping
357  WHERE
358     upper(trim(medicinal_product))
359      || upper(trim(dosage_form))
360      || upper(trim(drug_auth_country))
361      || upper(trim(drug_auth_number))
362      || upper(trim(generic_name)) =  upper(trim(PI_medicinalproduct))
363                                     || upper(trim(PI_drugdosageform))
364                                     || upper(trim(PI_drugauthorizationcountry))
365                                     || upper(trim(PI_drugauthorizationnumb))
366                                     || upper(trim(PI_suspect_product_generic_name));
367  
368      EXCEPTION
369          WHEN no_data_found THEN
370  
371          select count(1)
372          into v_drug_cnt
373          from s_drug where case_number =pkg_mg_util.g_scase_num
374          and DRUGCHARACTERIZATION=1 and
375          upper(trim(medicinalproduct))=upper(trim(PI_medicinalproduct));
376  
377  
378           SELECT COUNT(DISTINCT SUSPECT_DRUG_NAME) INTO V_CNT
379          FROM S_CASEPRODUCTLEVEL SCP WHERE 
380          UPPER(TRIM(SUSPECT_DRUG_NAME))=UPPER(TRIM(NVL(PI_suspect_drug_name,PI_medicinalproduct)));
381  
382  
383          if V_CNT>0 or v_drug_cnt>0 then
384            pkg_mg_util.p_mg_log_message(
385                  pi_scase_num    => pkg_mg_util.g_scase_num,
386                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
387                  pi_message_type => 'WARNING',
388                  pi_message      => 'Product Mapping Not found for product->'||nvl(PI_suspect_drug_name,PI_medicinalproduct),
389                  pi_thread_id    => NULL,
390                  pi_date_time    => systimestamp
391              );
392              end if;
393          end ;
394  
395  
396              po_tgt_prod_id := NULL;
397              po_tgt_prod_lic_id := NULL;
398              WHEN too_many_rows THEN
399              pkg_mg_util.p_mg_log_message(
400                  pi_scase_num    => pkg_mg_util.g_scase_num,
401                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
402                  pi_message_type => 'WARNING',
403                  pi_message      => 'multiple records found Product Mapping for product->'||nvl(PI_suspect_drug_name,PI_medicinalproduct),
404                  pi_thread_id    => NULL,
405                  pi_date_time    => systimestamp
406              );
