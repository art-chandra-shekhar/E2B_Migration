632      FUNCTION f_get_firsr_sus_product (
633          pi_tcase_id            IN NUMBER,
634          pi_case_num            IN VARCHAR2,
635          pi_prod_name           IN VARCHAR2,
636          pi_drug_name           IN VARCHAR2,
637          pi_argus_display_order IN NUMBER
638      ) RETURN NUMBER IS
639  
640          v_sus_flag       NUMBER := 0;
641          v_mIN_drug_id    NUMBER := 0;
642          v_prod_cnt       NUMBER := 0;
643          v_drug_cnt       NUMBER := 0;
644          v_min_drug_check NUMBER := 0;
645      BEGIN
646  
647          SELECT
648              COUNT(1)
649          INTO v_prod_cnt
650          FROM
651              s_caseproductlevel
652          WHERE
653                  case_number = pi_case_num
654              AND upper(trim(suspect_drug_name)) = upper(trim(pi_prod_name));
655  
656          SELECT
657              COUNT(1)
658          INTO v_drug_cnt
659          FROM
660              s_drug
661          WHERE
662                  drugcharacterization = 1
663              AND case_number = pi_case_num
664              AND upper(trim(medicinalproduct)) = upper(trim(pi_drug_name));
665  
666          SELECT
667              MIN(drug_seq)
668          INTO v_mIN_drug_id
669          FROM
670              s_drug
671          WHERE
672              case_number = pi_case_num and drugcharacterization = 1;
673  
674          SELECT
675              CASE
676                  WHEN EXISTS (
677                      SELECT
678                          1
679                      FROM
680                          s_drug
681                      WHERE
682                              case_number = pi_case_num
683                          AND upper(trim(medicinalproduct)) = upper(trim(pi_drug_name))
684                          AND drug_seq = v_MIN_drug_id
685                  ) THEN
686                      1
687                  ELSE
688                      0
689              END
690          INTO v_min_drug_check
691          FROM
692              dual;
693  
694          IF v_prod_cnt = 1 THEN
695              v_sus_flag := 1;
696          ELSIF
697              v_prod_cnt > 1
698              AND pi_argus_display_order = 1
699          THEN
700              v_sus_flag := 1;
701          ELSIF v_drug_cnt = 1 THEN
702              v_sus_flag := 1;
703          ELSIF
704              v_drug_cnt > 1
705              AND v_min_drug_check = 1
706          THEN
707              v_sus_flag := 1;
708          ELSE
709              v_sus_flag := 0;
710          END IF;
711  
712          RETURN v_sus_flag;
713  
714  
715      EXCEPTION
716          WHEN OTHERS THEN
717              pkg_mg_util.p_mg_log_message(
718                  pi_scase_num    => g_scase_num,
719                  pi_tcase_id     => g_tcase_id,
720                  pi_message_type => 'ERROR',
721                  pi_message      => 'Error: IN F_GET_FIRSR_SUS_PRODUCT: ' || sqlerrm,
722                  pi_thread_id    => NULL,
723                  pi_date_time    => systimestamp
724              );
725      END f_get_firsr_sus_product;
