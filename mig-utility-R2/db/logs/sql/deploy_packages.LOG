506      PROCEDURE p_mg_case_pat_hist (
507          src_case_num IN VARCHAR2,
508          pi_tcase_id  IN NUMBER
509      ) IS
510  
511          v_index         NUMBER := 0;
512          v_seq_num       NUMBER := 0;
513          CURSOR c_past_drug IS
514          SELECT
515              pd.patientpastdrugtherapy_seq,
516              pd.patient_seq,
517              pd.safetyreport_seq,
518              pd.patientdrugname,
519              pd.patientindicationmeddraversion,
520              pd.patientdrugindication,
521              pd.patientdrgreactionmeddraversion,
522              pd.patientdrugreaction,
523              pd.patientdrugstartdateformat,
524              pd.patientdrugstartdate,
525              pd.patientdrugenddateformat,
526              pd.patientdrugenddate
527          FROM
528              s_patientpastdrugtherapy pd
529          WHERE
530              pd.case_number = src_case_num;
531  
532          CURSOR c_med_hist IS
533          SELECT
534              mh.medicalhistoryepisode_seq,
535              mh.patient_seq,
536              mh.safetyreport_seq,
537              mh.patientepisodenamemeddraversion,
538              mh.patientepisodename,
539              mh.patientmedicalcomment,
540              mh.patientmedicalstartdateformat,
541              mh.patientmedicalstartdate,
542              mh.patientmedicalenddateformat,
543              mh.patientmedicalenddate,
544              mh.patientmedicalcontinue
545          FROM
546              s_medicalhistoryepisode mh
547          WHERE
548              mh.case_number = src_case_num;
549  
550          TYPE t_case_pat_hist_tab IS
551              TABLE OF tcase_pat_hist%rowtype INDEX BY PLS_INTEGER;
552          v_case_pat_hist t_case_pat_hist_tab;
553      BEGIN
554          FOR v_row IN c_past_drug LOOP
555              v_index := v_index + 1;
556              v_seq_num := v_seq_num + 1;
557              v_case_pat_hist(v_index).case_id := pi_tcase_id;
558              v_case_pat_hist(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_PAT_HIST', 'SEQ_NUM');
559              v_case_pat_hist(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
560              v_case_pat_hist(v_index).indication := v_row.patientdrugindication;
561              v_case_pat_hist(v_index).reaction := v_row.patientdrugreaction;
562              pkg_mg_buss_rules.p_meddra_map_br001('INDICATION',
563                                                   v_row.patientdrugindication,
564                                                   v_row.patientdrugindication,
565                                                   v_row.patientdrugindication,
566                                                   v_case_pat_hist(v_index).ind_llt_code,
567                                                   v_case_pat_hist(v_index).ind_llt,
568                                                   v_case_pat_hist(v_index).ind_pt_code,
569                                                   v_case_pat_hist(v_index).ind_coded,
570                                                   v_case_pat_hist(v_index).ind_hlt_code,
571                                                   v_case_pat_hist(v_index).ind_hlt,
572                                                   v_case_pat_hist(v_index).ind_hlgt_code,
573                                                   v_case_pat_hist(v_index).ind_hlgt,
574                                                   v_case_pat_hist(v_index).ind_soc_code,
575                                                   v_case_pat_hist(v_index).ind_soc,
576                                                   v_case_pat_hist(v_index).ind_code_status,
577                                                   v_case_pat_hist(v_index).ind_dict_id);
578  
579              pkg_mg_buss_rules.p_meddra_map_br001('REACTION',
580                                                   v_row.patientdrugreaction,
581                                                   v_row.patientdrugreaction,
582                                                   v_row.patientdrugreaction,
583                                                   v_case_pat_hist(v_index).ind_llt_code,
584                                                   v_case_pat_hist(v_index).ind_llt,
585                                                   v_case_pat_hist(v_index).ind_pt_code,
586                                                   v_case_pat_hist(v_index).ind_coded,
587                                                   v_case_pat_hist(v_index).ind_hlt_code,
588                                                   v_case_pat_hist(v_index).ind_hlt,
589                                                   v_case_pat_hist(v_index).ind_hlgt_code,
590                                                   v_case_pat_hist(v_index).ind_hlgt,
591                                                   v_case_pat_hist(v_index).ind_soc_code,
592                                                   v_case_pat_hist(v_index).ind_soc,
593                                                   v_case_pat_hist(v_index).ind_code_status,
594                                                   v_case_pat_hist(v_index).ind_dict_id);
595  
596              pkg_mg_buss_rules.p_get_partial_date('PATIENTPASTDRUGTHERAPY',
597                                                   v_row.patientdrugstartdateformat,
598                                                   v_row.patientdrugstartdate,
599                                                   v_case_pat_hist(v_index).start_date,
600                                                   v_case_pat_hist(v_index).start_date_res,
601                                                   v_case_pat_hist(v_index).start_date_partial);
602  
603              pkg_mg_buss_rules.p_get_partial_date('PATIENTPASTDRUGTHERAPY',
604                                                   v_row.patientdrugenddateformat,
605                                                   v_row.patientdrugenddate,
