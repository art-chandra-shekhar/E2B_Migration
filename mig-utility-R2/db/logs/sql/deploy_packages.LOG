509                  pkg_mg_util.p_mg_log_message(
510                      pi_scase_num    => g_scase_num,
511                      pi_tcase_id     => g_tcase_id,
512                      pi_message_type => 'WARNING',
513                      pi_message      => 'License Not configured for this trade_name:'
514                                    || pi_s_trade_name
515                                    || ' having License Number:'
516                                    || pi_s_lic_num
517                                    || ' and Country->'
518                                    || v_s_country||' and pi_license_id->'||pi_license_id,
519                      pi_thread_id    => NULL,
520                      pi_date_time    => systimestamp
521                  );
522                  RETURN t_lic_id;
523                 WHEN OTHERS THEN
524              pkg_mg_util.p_mg_log_message(
525                  pi_scase_num    => g_scase_num,
526                  pi_tcase_id     => g_tcase_id,
527                  pi_message_type => 'ERROR',
528                  pi_message      => 'Error: IN F_GET_TGT_LIC_ID: ' || sqlerrm,
529                  pi_thread_id    => NULL,
530                  pi_date_time    => systimestamp
531              );
532                  return t_lic_id;
533  
534    END;
535  
536                  RETURN t_lic_id;
537              WHEN too_many_rows THEN
538                  pkg_mg_util.p_mg_log_message(
539                      pi_scase_num    => g_scase_num,
540                      pi_tcase_id     => g_tcase_id,
541                      pi_message_type => 'WARNING',
542                      pi_message      => 'Multipel Licenses configured for this trade_name:'
543                                    || pi_s_trade_name
544                                    || ' having License Number:'
545                                    || pi_s_lic_num
546                                    || ' and Country->'
547                                    || v_s_country,
548                      pi_thread_id    => NULL,
549                      pi_date_time    => systimestamp
550                  );
551          --what to return from here.
552          END;
553  
554      EXCEPTION
555          WHEN OTHERS THEN
556              pkg_mg_util.p_mg_log_message(
557                  pi_scase_num    => g_scase_num,
558                  pi_tcase_id     => g_tcase_id,
559                  pi_message_type => 'ERROR',
560                  pi_message      => 'Error: IN F_GET_TGT_LIC_ID: ' || sqlerrm,
