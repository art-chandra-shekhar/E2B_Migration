421      PROCEDURE P_MG_FIRST_LAST_DOSE_CALC(
422  PI_FIRST_DOSE IN DATE,
423  PI_LAST_DOSE IN DATE,
424  PI_START_DATE IN DATE,
425  PI_START_DATE_RES IN NUMBER,
426  PI_START_DATE_PARTIAL IN VARCHAR2,
427  PI_STOP_DATE IN DATE,
428  PI_STOP_DATE_RES IN NUMBER,
429  PI_STOP_DATE_PARTIAL IN VARCHAR2,
430  PO_FIRST_DOSE OUT DATE,
431  PO_FIRST_DOSE_RES OUT NUMBER,
432  PO_FIRST_DOSE_PARTIAL OUT VARCHAR2,
433  PO_LAST_DOSE OUT DATE,
434  PO_LAST_DOSE_RES OUT NUMBER,
435  PO_LAST_DOSE_PARTIAL OUT VARCHAR2
436  )
437  AS
438  BEGIN
439  
440  /*FOR CALCULATING THE FIRST DOSE*/
441  IF PI_FIRST_DOSE>PI_START_DATE THEN
442  PO_FIRST_DOSE:=PI_START_DATE;
443  PO_FIRST_DOSE_RES:=PI_START_DATE_RES;
444  PO_FIRST_DOSE_PARTIAL:=PI_START_DATE_PARTIAL;
445  END IF;
446  
447  
448  /*FOR CALCULATING THE LAST DOSE*/
449  IF PI_LAST_DOSE<PI_STOP_DATE THEN
450  PO_LAST_DOSE:=PI_STOP_DATE;
451  PO_LAST_DOSE_RES:=PI_STOP_DATE_RES;
452  PO_LAST_DOSE_PARTIAL:=PI_STOP_DATE_PARTIAL;
453  END IF;
454  
455  
456  EXCEPTION WHEN OTHERS THEN
457   pkg_mg_util.p_mg_log_message(
458                  pi_scase_num    => pkg_mg_util.g_scase_num,
459                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
460                  pi_message_type => 'ERROR',
461                  pi_message      => 'ERROR IN PROCEDURE:P_MG_FIRST_LAST_DOSE_CALC :'||SQLERRM,
462                  pi_thread_id    => NULL,
463                  pi_date_time    => systimestamp
464              );
465  END P_MG_FIRST_LAST_DOSE_CALC;
