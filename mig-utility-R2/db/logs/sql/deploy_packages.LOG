566        FUNCTION f_var_to_date (
567          pi_table_name     IN VARCHAR2,
568          pi_date_format    IN NUMBER,
569          pi_date_in_number IN VARCHAR2
570      )RETURN DATE IS
571       v_value VARCHAR2(50);
572      po_date DATE := NULL;
573      BEGIN
574          IF pi_date_in_number IS NULL THEN
575              po_date := NULL;
576              RETURN po_date;
577          END IF;
578  
579  IF VALIDATE_CONVERSION((PI_DATE_IN_NUMBER) AS DATE,'DD-MM-RR') = 1 THEN--exception partial date mapping
580  
581     po_date := TO_DATE ( PI_DATE_IN_NUMBER, 'DD-MM-RR' );
582     RETURN po_date;
583  END IF;
584     v_value         := TRIM(TO_CHAR(PI_DATE_IN_NUMBER));
585      /*first use format if present*/
586          IF pi_date_format IS NOT NULL THEN
587              IF pi_date_format = 602 THEN
588                  po_date := TO_DATE ( v_value, 'YYYY' );
589              ELSIF pi_date_format = 610 THEN
590                  po_date := TO_DATE ( v_value, 'YYYYMM' );
591              ELSIF pi_date_format = 102 THEN
592                  po_date := TO_DATE ( v_value, 'YYYYMMDD' );
593              ELSIF pi_date_format = 203 THEN
594                  po_date := TO_DATE ( v_value, 'YYYYMMDDHH24MI' );
595              ELSE
596                  po_date := NULL;
597              END IF;
598  
599   /*use length if format not present*/
600          ELSE
601              IF length(v_value) = 4 THEN
602                  po_date := TO_DATE ( v_value, 'YYYY' );
603              ELSIF length(v_value) = 6 THEN
604                  po_date := TO_DATE ( v_value, 'YYYYMM' );
605  
606              ELSIF length(v_value) = 8 THEN
607                  po_date := TO_DATE ( v_value, 'YYYYMMDD' );
608              ELSIF length(v_value) = 12 THEN
609                  po_date := TO_DATE ( v_value, 'YYYYMMDDHH24MI' );
610              ELSE
611                  po_date := NULL;
612              END IF;
613          END IF;
614  
615      RETURN PO_DATE;
616  
617      EXCEPTION
618          WHEN OTHERS THEN
619              pkg_mg_util.p_mg_log_message(
620                  pi_scase_num    => pkg_mg_util.g_scase_num,
621                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
622                  pi_message_type => 'ERROR',
623                  pi_message      => 'Error: IN f_var_to_date Called from table'
624                                || pi_table_name
625                                || ':'
626                                || sqlerrm,
627                  pi_thread_id    => NULL,
628                  pi_date_time    => systimestamp
629              );
630      END f_var_to_date;
