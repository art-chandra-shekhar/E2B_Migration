2898      PROCEDURE p_mg_case_reporters (
2899          src_case_num IN VARCHAR2,
2900          pi_tcase_id  IN NUMBER
2901      ) IS
2902  
2903          CURSOR c_case_reporters IS
2904          SELECT
2905              ps.reportergivename,
2906              ps.reporterfamilyname,
2907              ps.qualification,
2908              ps.reporterorganization,
2909              ps.reporterstreet,
2910              ps.reporterdepartment,
2911              ps.reportercity,
2912              ps.reporterstate,
2913              ps.reporterpostcode,
2914              ps.reportercountry,
2915              ps.reportertitle,
2916              ps.reportermiddlename,
2917              ps.case_number,
2918                    PS.PRIMARYSOURCE_SEQ,
2919    SRL.AUTHORITY_NUMBER,
2920    SRL.ARGUS_SEQUENCE_NUMBER,
2921    SRL.ARGUS_DISPLAY_ORDER,
2922    SRL.REPORTER_TYPE,
2923    SRL.HCP_FLAG,
2924    SRL.REPORTER_FIRST_NAME,
2925    SRL.REPORTER_LAST_NAME,
2926    SRL.INSTITUTION_NAME,
2927    SRL.REPORTER_ADDRESS,
2928    SRL.FLAG_OF_PRIMARY_REPORTER,
2929    SRL.GEN_SEQ
2930          FROM
2931              s_primarysource ps
2932              inner join s_reporterlevel srl
2933              on ps.case_number=srl.case_number and ps.gen_seq=srl.gen_seq
2934          WHERE
2935              ps.case_number = src_case_num ORDER BY SRL.ARGUS_DISPLAY_ORDER;
2936  
2937          v_index          PLS_INTEGER := 0;
2938          TYPE v_case_reporters_tab IS
2939              TABLE OF tcase_reporters%rowtype INDEX BY PLS_INTEGER;
2940          v_case_reporters v_case_reporters_tab;
2941      BEGIN
2942          FOR v_row IN c_case_reporters LOOP
2943              v_index := v_index + 1;
2944              v_case_reporters(v_index).case_id := pi_tcase_id;
2945              v_case_reporters(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_REPORTERS', 'SEQ_NUM');
2946              v_case_reporters(v_index).sort_id := v_index;
2947              v_case_reporters(v_index).first_name := nvl(v_row.reportergivename,v_row.REPORTER_FIRST_NAME);
2948              v_case_reporters(v_index).last_name := nvl(v_row.reporterfamilyname,v_row.REPORTER_LAST_NAME);
2949              v_case_reporters(v_index).middle_name := v_row.reportermiddlename;
2950              v_case_reporters(v_index).institution := nvl(v_row.reporterorganization,v_row.INSTITUTION_NAME);
2951              v_case_reporters(v_index).address := nvl(v_row.reporterstreet,v_row.REPORTER_ADDRESS);
2952              v_case_reporters(v_index).department := v_row.reporterdepartment;
2953              v_case_reporters(v_index).city := v_row.reportercity;
2954              v_case_reporters(v_index).state := v_row.reporterstate;
2955              v_case_reporters(v_index).postcode := v_row.reporterpostcode;
2956              v_case_reporters(v_index).prefix := v_row.reportertitle;
2957              v_case_reporters(v_index).country_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Countries', v_row.reportercountry);
2958  
2959              v_case_reporters(v_index).reporter_type := pkg_mg_util.f_mg_codelist_code('E2B', 'Reporter Type', v_row.qualification);
2960               v_case_reporters(v_index).country:= v_row.reportercountry;
2961  
2962              v_case_reporters(v_index).hcp_flag := case when UPPER(V_ROW.HCP_FLAG)=1 THEN 1
2963                                                      ELSE 0 END;
2964              V_CASE_REPORTERS(V_INDEX).PRIMARY_CONTACT:=case when UPPER(V_ROW.FLAG_OF_PRIMARY_REPORTER)='YES' THEN 1
2965                                                                  WHEN UPPER(V_ROW.FLAG_OF_PRIMARY_REPORTER)='NO' THEN 0 
2966                                                                  ELSE NULL END; 
2967              v_case_reporters(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
2968  
2969              pkg_mg_util.p_insert_seq_mapping('S_PRIMARYSOURCE',
2970                                               'CASE_REPORTERS',
2971                                               'PRIMARYSOURCE_SEQ',
2972                                               'SEQ_NUM',
2973                                               V_ROW.PRIMARYSOURCE_SEQ,
2974                                                     v_case_reporters(v_index).seq_num);
2975  
2976  
2977          END LOOP;
2978  
2979          FOR i IN 1..v_index LOOP
2980              INSERT INTO tcase_reporters VALUES v_case_reporters ( i );
2981  
2982          END LOOP;
2983  
2984      EXCEPTION
2985          WHEN OTHERS THEN
2986              pkg_mg_util.p_mg_log_message(
2987                  pi_scase_num    => src_case_num,
2988                  pi_tcase_id     => pi_tcase_id,
2989                  pi_message_type => 'ERROR',
2990                  pi_message      => 'P_MG_CASE_REPORTERS ' || dbms_utility.format_error_stack,
2991                  pi_thread_id    => NULL,
2992                  pi_date_time    => systimestamp
2993              );
2994  
2995              raise_application_error(-20001, sqlerrm);
2996      END p_mg_case_reporters;
