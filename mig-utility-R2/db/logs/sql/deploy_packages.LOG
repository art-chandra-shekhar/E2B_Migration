3228      PROCEDURE p_mg_cmn_reg_reports (
3229          src_case_num IN VARCHAR2,
3230          pi_tcase_id  IN NUMBER
3231      ) IS
3232  
3233          CURSOR c_cmn_reg_reports IS
3234          SELECT
3235              ss.*,
3236              (
3237                  SELECT
3238                      seq_num
3239                  FROM
3240                      tcase_product
3241                  WHERE
3242                          case_id = pi_tcase_id
3243                      AND first_sus_prod = 1
3244              ) t_prod_seq_num,
3245              (
3246                  SELECT
3247                      CASE WHEN NVL(product_id,PAT_EXPOSURE)=0 THEN NULL
3248                      ELSE
3249                      NVL(product_id,PAT_EXPOSURE) END
3250                  FROM
3251                      tcase_product
3252                  WHERE
3253                          case_id = pi_tcase_id
3254                      AND first_sus_prod = 1
3255              ) t_prod_id,
3256              (SELECT SERIOUSNESS FROM TCASE_MASTER 
3257              WHERE CASE_NUM=SRC_CASE_NUM ) V_SERIOUSNESS,
3258              (select tlrt.INCL_TRIAL
3259              from tcase_master tcm
3260              inner join tlm_report_type tlrt
3261              on tlrt.rpt_type_id=tcm.rpt_type_id
3262              where tcm.case_num=ss.case_number
3263              ) clin_flag
3264          FROM
3265              s_submissionlevel ss
3266          WHERE
3267              ss.case_number = src_case_num;
3268  
3269          v_index            PLS_INTEGER := 0;
3270          TYPE v_cmn_reg_reports_tab IS
3271              TABLE OF tcmn_reg_reports%rowtype INDEX BY PLS_INTEGER;
3272          v_cmn_reg_reports  v_cmn_reg_reports_tab;
3273  
3274      /*case_reg_REPORT*/
3275  
3276          TYPE v_case_reg_reports_tab IS
3277              TABLE OF tcase_reg_reports%rowtype INDEX BY PLS_INTEGER;
3278          v_case_reg_reports v_case_reg_reports_tab;
3279      BEGIN
3280          FOR v_row IN c_cmn_reg_reports LOOP
3281              v_index := v_index + 1;
3282              v_cmn_reg_reports(v_index).reg_report_id := pkg_mg_util.f_mg_seq_num('CMN_REG_REPORTS', 'REG_REPORT_ID');
3283  
3284  
3285  
3286   v_cmn_reg_reports(v_index).schedule_date :=pkg_mg_util.f_var_to_date('cmn_reg_reports->date_scheduled',null,v_row.scheduled_date);
3287  
3288              v_cmn_reg_reports(v_index).date_scheduled := pkg_mg_util.f_var_to_date('cmn_reg_reports->date_scheduled',null,v_row.scheduled_date);
3289  
3290              v_cmn_reg_reports(v_index).date_generated := nvl(
3291              pkg_mg_util.f_var_to_date('cmn_reg_reports->report_generated_date',null,v_row.report_generated_date),
3292                v_cmn_reg_reports(v_index).date_scheduled 
3293              );
3294  
3295              v_cmn_reg_reports(v_index).date_submitted := nvl(
3296  pkg_mg_util.f_var_to_date('cmn_reg_reports->report_submitted_date',null,v_row.report_submitted_date),
3297                  v_cmn_reg_reports(v_index).date_generated
3298              );
3299  
3300   v_cmn_reg_reports(v_index).due_date := v_cmn_reg_reports(v_index).date_submitted ;
3301              v_cmn_reg_reports(v_index).date_approved :=  v_cmn_reg_reports(v_index).date_scheduled;
3302  
3303              v_cmn_reg_reports(v_index).date_submission_determined := null;
3304  
3305              v_cmn_reg_reports(v_index).product_id := v_row.t_prod_id;
3306              dbms_output.put_line('product_id->' || v_row.t_prod_id);
3307              BEGIN
3308                  SELECT
3309                      tll.license_id
3310                  INTO v_cmn_reg_reports(v_index).license_id
3311                  FROM
3312                           tlm_lic_products tllp
3313                      INNER JOIN tlm_license tll ON ( tllp.license_id = tll.license_id )
3314                  WHERE
3315                      tllp.product_id = v_row.t_prod_id;
3316  
3317              EXCEPTION
3318                 WHEN no_data_found THEN
3319              pkg_mg_util.p_mg_log_message(
3320                  pi_scase_num    => pkg_mg_util.g_scase_num,
3321                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
3322                  pi_message_type => 'WARNING',
3323                  pi_message      => 'License Not found in CMN_REG_REPORT',
3324                  pi_thread_id    => NULL,
3325                  pi_date_time    => systimestamp
3326              );
3327  
3328                     WHEN too_many_rows THEN
3329                     IF V_ROW.CLIN_FLAG=1 THEN
3330  
3331                      SELECT
3332                      tll.license_id
3333                  INTO v_cmn_reg_reports(v_index).license_id
3334                  FROM
3335                           tlm_lic_products tllp
3336                      INNER JOIN tlm_license tll ON ( tllp.license_id = tll.license_id )
3337                  WHERE
3338                      tllp.product_id = v_row.t_prod_id AND TLL.LICENSE_TYPE_ID=1;
3339                      ELSE
3340                       SELECT
3341                      tll.license_id
3342                  INTO v_cmn_reg_reports(v_index).license_id
3343                  FROM
3344                           tlm_lic_products tllp
3345                      INNER JOIN tlm_license tll ON ( tllp.license_id = tll.license_id )
3346                  WHERE
3347                      tllp.product_id = v_row.t_prod_id AND TLL.LICENSE_TYPE_ID=4;
3348                      END IF;
3349  
3350              END;
3351  
3352              v_cmn_reg_reports(v_index).prod_seq_num := v_row.t_prod_seq_num;
3353  
3354              v_cmn_reg_reports(v_index).last_state_id := 6;
3355              v_cmn_reg_reports(v_index).state_id := 6;
3356              v_cmn_reg_reports(v_index).report_form_type := NULL;
3357              v_cmn_reg_reports(v_index).group_id := NULL;
3358              v_cmn_reg_reports(v_index).determined_user_id := NULL;
3359  
3360              v_cmn_reg_reports(v_index).report_form_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Report Form', v_row.report_form);
3361  
3362              v_cmn_reg_reports(v_index).last_update_time := pkg_mg_util.f_mg_key_val('Migration Date');
3363              v_cmn_reg_reports(v_index).no_followup_downgrade := v_row.flag_of_downgrade_report;
3364              v_cmn_reg_reports(v_index).followup_num := nvl(v_row.followup_number, 0);
3365              v_cmn_reg_reports(v_index).rpt_comment := v_row.report_comments;
3366              v_cmn_reg_reports(v_index).owner_id := pkg_mg_util.f_mg_key_val('Migration User Id');
3367              v_cmn_reg_reports(v_index).agency_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Reporting Destination', v_row.reporting_destination
3368              );
3369  
3370              v_cmn_reg_reports(v_index).user_id := pkg_mg_util.f_mg_key_val('Migration User Id');
3371              v_cmn_reg_reports(v_index).tracking_num := src_case_num;
3372              v_cmn_reg_reports(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
3373  
3374  
3375                  v_cmn_reg_reports(v_index).aware_method := 0;
3376               v_cmn_reg_reports(v_index).TIMEFRAME := CASE WHEN V_ROW.V_SERIOUSNESS=1 THEN 15 
3377                                                                                      ELSE 30 END;
3378               v_cmn_reg_reports(v_index).MESSAGE_TYPE_ID:=1;
3379              v_cmn_reg_reports(v_index).auto_distribute_reports := 0;
3380  
3381  
3382              BEGIN
3383  
3384              select pref_term, pref_term_j, body_sys, body_sys_j
3385              into v_cmn_reg_reports(v_index).event,v_cmn_reg_reports(v_index).event_j
3386              ,v_cmn_reg_reports(v_index).body_sys,v_cmn_reg_reports(v_index).body_sys_j
3387              from tcase_event
3388              where case_id=pi_tcase_id
3389              and sort_id=(select min(sort_id) from tcase_event where case_id=pi_tcase_id);
3390  
3391              EXCEPTION
3392              WHEN OTHERS THEN 
3393              NULL;
3394              END;
3395  
3396  
3397  --            pkg_mg_buss_rules.p_get_body_sys_event(v_cmn_reg_reports(v_index).body_sys,  v_cmn_reg_reports(v_index).event);
3398              v_case_reg_reports(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
3399              v_cmn_reg_reports(v_index).SUBMIT_REQUIRED:=1;
3400               v_cmn_reg_reports(v_index).AUTO_SCHED:=0;
3401               v_cmn_reg_reports(v_index).TEMPLATE_ID:=NULL;
3402               v_cmn_reg_reports(v_index).METHOD:=0;
3403               v_cmn_reg_reports(v_index).OUTPUT_STATUS:=0;
3404               v_cmn_reg_reports(v_index).PROTECT:=0;
3405               v_cmn_reg_reports(v_index).SUSAR:=1;
3406               v_cmn_reg_reports(v_index).BLIND_STUDY_PRODUCT:=0;
3407               v_cmn_reg_reports(v_index).NULLIFICATION:=0;
3408               v_cmn_reg_reports(v_index).PREV_ESM_RPT_ID:=-1;
3409               v_cmn_reg_reports(v_index).NO_FOLLOWUP_DOWNGRADE:=0;
3410               v_cmn_reg_reports(v_index).LOCAL_REPORT:=0;
3411               v_cmn_reg_reports(v_index).GENERATE_RPT:=1;
3412               v_cmn_reg_reports(v_index).AMENDMENT:=0;
3413               v_cmn_reg_reports(v_index).URGENT_REPORT:=0;
3414  
3415                  select tcm.rev ,tcm.INIT_REPT_DATE,tcm.INIT_REPT_DATE
3416                  into v_cmn_reg_reports(v_index).CASE_REV,
3417                  v_cmn_reg_reports(v_index).aware_date,
3418                      v_cmn_reg_reports(v_index).SAFETY_DATE
3419                  from tcase_master tcm 
3420                  where  tcm.case_num=v_row.case_number;
3421  
3422  
3423                  v_cmn_reg_reports(v_index).TEMPLATE_ID := 1;
3424  
3425              /*case_reg_report*/
3426  
3427              v_case_reg_reports(v_index).case_id := pi_tcase_id;
3428              v_case_reg_reports(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_REG_REPORTS', 'SEQ_NUM');
3429              v_case_reg_reports(v_index).reg_report_id := v_cmn_reg_reports(v_index).reg_report_id;
3430              v_case_reg_reports(v_index).date_assessed := NULL;
3431              v_case_reg_reports(v_index).sort_id := v_index;
3432             BEGIN
3433             SELECT 
3434             COUNTRY
3435             INTO  v_cmn_reg_reports(v_index).country_id 
3436             FROM tlm_regulatory_contact
3437             WHERE AGENCY_ID=v_cmn_reg_reports(v_index).AGENCY_ID;
3438             EXCEPTION
3439             WHEN OTHERS THEN
3440             v_cmn_reg_reports(v_index).country_id:=null;
3441             END;
3442  
3443             v_cmn_reg_reports(v_index).SUBMIT_NOTES:='Migrated from Sebela';
3444              pkg_mg_util.p_insert_seq_mapping('S_SUBMISSIONLEVEL',
3445                                               'CMN_REG_REPORTS',
3446                                               'SUBMISSION_ID',
3447                                               'REG_REPORT_ID',
3448                                               V_ROW.SUBMISSION_ID,
3449                                               v_cmn_reg_reports(v_index).reg_report_id);
3450  
3451          END LOOP;
3452  
3453          FOR i IN 1..v_index LOOP
3454              INSERT INTO tcmn_reg_reports VALUES v_cmn_reg_reports ( i );
3455  
3456              INSERT INTO tcase_reg_reports VALUES v_case_reg_reports ( i );
3457  
3458          END LOOP;
3459  
3460      EXCEPTION
3461          WHEN OTHERS THEN
3462              pkg_mg_util.p_mg_log_message(
3463                  pi_scase_num    => src_case_num,
3464                  pi_tcase_id     => pi_tcase_id,
3465                  pi_message_type => 'ERROR',
3466                  pi_message      => 'P_MG_CMN_REG_REPORTS ' || dbms_utility.format_error_stack,
3467                  pi_thread_id    => NULL,
3468                  pi_date_time    => systimestamp
3469              );
3470  
3471              raise_application_error(-20001, sqlerrm);
3472      END p_mg_cmn_reg_reports;
