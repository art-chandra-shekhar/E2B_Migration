1688              );
1689  
1690              v_case_prod_drugs(v_index).obtain_drug_country_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Countries', v_row.drugauthorizationcountry
1691              );
1692  
1693              v_case_prod_drugs(v_index).drug_auth_country_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Countries', v_row.obtaindrugcountry
1694              );
1695  
1696              v_case_prod_drugs(v_index).act_taken_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Action Taken', v_row.actiondrug);
1697  
1698              v_case_prod_drugs(v_index).delay_seconds := NULL;--bl
1699              v_case_prod_drugs(v_index).latency_seconds := NULL;--BL
1700              v_case_prod_drugs(v_index).latency_seconds := v_row.drugstartperiod;
1701              v_case_prod_drugs(v_index).dechallenge := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Dechallenge', v_row.dechallenge);
1702  
1703              v_case_prod_drugs(v_index).rechallenge := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Rechallenge', v_row.rechallenge);
1704  
1705              v_case_prod_drugs(v_index).delay := NULL;--BL
1706              v_case_prod_drugs(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1707              v_case_prod_drugs(v_index).interaction :=
1708                  CASE
1709                      WHEN v_row.drugcharacterization = 3 THEN
1710                          1
1711                      ELSE -1
1712                  END;
1713  IF v_case_prod_drugs(v_index).FORMULATION_ID IS NULL THEN
1714  v_case_prod_drugs(v_index).FORMULATION_ID:=pkg_mg_util.f_mg_codelist_code('E2B', 'Formulation', v_row.drugdosageform);
1715  END IF;
1716              v_case_prod_drugs(v_index).first_dose := NULL;--INITIALIZING THEM NULL AT STARTING
1717              v_case_prod_drugs(v_index).last_dose := NULL;--INITIALIZING THEM NULL AT STARTING
1718  /*CASE DOSE REGIMENS*/
1719              FOR v_row1 IN c_case_dose_regimens(v_row.drug_seq_num) LOOP
1720                  v_index1 := v_index1 + 1;
1721                  v_case_dose_regimens(v_index1).case_id := pi_tcase_id;
1722                  v_case_dose_regimens(v_index1).seq_num := v_case_product(v_index).seq_num;
1723                  v_case_dose_regimens(v_index1).log_no := pkg_mg_util.f_mg_seq_num('CASE_DOSE_REGIMENS', 'LOG_NO');
1724                  pkg_mg_buss_rules.p_get_partial_date('CASE_DOSE_REGIMENS',
1725                                                       v_row1.drugstartdateformat,
1726                                                       v_row1.drugstartdate,
1727                                                       v_case_dose_regimens(v_index1).start_datetime,
1728                                                       v_case_dose_regimens(v_index1).start_datetime_res,
1729                                                       v_case_dose_regimens(v_index1).start_date_partial);
1730  
1731                  pkg_mg_buss_rules.p_get_partial_date('CASE_DOSE_REGIMENS',
1732                                                       v_row1.drugenddateformat,
1733                                                       v_row1.drugenddate,
1734                                                       v_case_dose_regimens(v_index1).stop_datetime,
1735                                                       v_case_dose_regimens(v_index1).stop_datetime_res,
1736                                                       v_case_dose_regimens(v_index1).stop_date_partial);
1737  
1738                  IF v_case_dose_regimens(v_index1).stop_datetime IS NULL THEN
1739                      v_case_dose_regimens(v_index1).ongoing := 1;
1740                  ELSE
1741                      v_case_dose_regimens(v_index1).ongoing := 0;
1742                  END IF;
1743  
1744                  pkg_mg_buss_rules.p_mg_first_last_dose_calc(v_case_prod_drugs(v_index).first_dose,
1745                                                              v_case_prod_drugs(v_index).last_dose,
1746                                                              v_case_dose_regimens(v_index1).start_datetime,
1747                                                              v_case_dose_regimens(v_index1).start_datetime_res,
1748                                                              v_case_dose_regimens(v_index1).start_date_partial,
1749                                                              v_case_dose_regimens(v_index1).stop_datetime,
1750                                                              v_case_dose_regimens(v_index1).stop_datetime_res,
1751                                                              v_case_dose_regimens(v_index1).stop_date_partial,
1752                                                              v_case_prod_drugs(v_index).first_dose,
1753                                                              v_case_prod_drugs(v_index).first_dose_res,
1754                                                              v_case_prod_drugs(v_index).first_dose_partial,
1755                                                              v_case_prod_drugs(v_index).last_dose,
1756                                                              v_case_prod_drugs(v_index).last_dose_res,
1757                                                              v_case_prod_drugs(v_index).last_dose_partial);
1758  
1759                  v_case_dose_regimens(v_index1).off_label := NULL;
1760                  v_case_dose_regimens(v_index1).dose := v_row1.drugstructuredosagenumb;
1761                  v_case_dose_regimens(v_index1).dose_unit_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Dose Units', v_row1.drugstructuredosageunit
1762                  );--highly in doubt
1763                  v_case_dose_regimens(v_index1).freq_id := NULL;
1764                  v_case_dose_regimens(v_index1).admin_route_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Admin Route', v_row1.drugadministrationroute
1765                  );
1766  
1767                  v_case_dose_regimens(v_index1).daily_dose := NULL;
1768                  v_case_dose_regimens(v_index1).daily_dose_unit_id := NULL;
1769                  v_case_dose_regimens(v_index1).exp_date := NULL;
1770                  v_case_dose_regimens(v_index1).exp_date_res := NULL;
1771                  v_case_dose_regimens(v_index1).total_reg_dose := NULL;
1772                  v_case_dose_regimens(v_index1).tot_reg_dose_unit_id := NULL;
1773                  v_case_dose_regimens(v_index1).sort_id := NULL;
1774                  v_case_dose_regimens(v_index1).dose_no := v_row1.drugstructuredosagenumb;
1775                  v_case_dose_regimens(v_index1).par_admin_route := pkg_mg_util.f_mg_codelist_code('E2B', 'Admin Route', v_row1.drugparadministration
1776                  );
1777  
1778                  v_case_dose_regimens(v_index1).exp_date_partial := NULL;
1779                  v_case_dose_regimens(v_index1).lot_no := v_row1.drugbatchnumb;
1780                  v_case_dose_regimens(v_index1).duration_seconds := NULL;--br015
1781                  v_case_dose_regimens(v_index1).last_update_time := pkg_mg_util.f_mg_key_val('Migration Date');
1782                  v_case_dose_regimens(v_index1).duration := v_row1.drugtreatmentduration;
1783                  v_case_dose_regimens(v_index1).dose_description := v_row1.drugdosagetext;
1784                  v_case_dose_regimens(v_index1).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1785              END LOOP;
1786  
1787          END LOOP;
1788  
1789          FOR i IN 1..v_index LOOP
1790              INSERT INTO tcase_product VALUES v_case_product ( i );
1791  
1792              INSERT INTO tcase_prod_drugs VALUES v_case_prod_drugs ( i );
1793  
1794          END LOOP;
1795  
1796          FOR i IN 1..v_index1 LOOP
1797              INSERT INTO tcase_dose_regimens VALUES v_case_dose_regimens ( i );
1798  
1799          END LOOP;
1800  
1801          UPDATE tcase_product
1802          SET
1803              study_product_num = ROWNUM
1804          WHERE
1805                  case_id = pi_tcase_id
1806              AND co_drug_code = 'Study Drug';
1807  
1808          UPDATE tcase_study cs
1809          SET
1810              product_count = (
1811                  SELECT
1812                      COUNT(1)
1813                  FROM
1814                      tcase_product cp
1815                  WHERE
1816                          cp.case_id = cs.case_id
1817                      AND co_drug_code = 'Study Drug'
1818              )
1819          WHERE
1820              case_id = pi_tcase_id;
1821  
