2128              );
2129  
2130              raise_application_error(-20001, sqlerrm);
2131      END p_mg_case_event_detail;
2132  
2133      PROCEDURE p_mg_case_event_assess (
2134          src_case_num IN VARCHAR2,
2135          pi_tcase_id  IN NUMBER
2136      ) IS
2137  
2138          CURSOR c_case_event_assess_cau IS
2139          SELECT
2140              tcm.case_num,
2141              tcp.case_id,
2142              tcp.seq_num                prod_seq_num,
2143              tce.seq_num                event_seq_num,
2144              tcp.product_id,
2145              tcp.pat_exposure,
2146              ( pkg_mg_util.f_fetch_seq_map_val('S_CASEPRODUCTLEVEL', 'CASE_PRODUCT', 'PROD_SEQ_NUM', 'SEQ_NUM', tcp.seq_num,
2147                                                'S') ) AS s_prod_seq_num,
2148              ( pkg_mg_util.f_fetch_seq_map_val('S_CASEEVENTLEVEL', 'CASE_EVENT', 'EVENT_SEQ_NUM', 'SEQ_NUM', tce.seq_num,
2149                                                'S') ) AS s_event_seq_num
2150          FROM
2151              tcase_product tcp,
2152              tcase_event   tce,
2153              tcase_master  tcm
2154          WHERE
2155                  tcp.case_id = tce.case_id
2156              AND tcp.case_id = tcm.case_id
2157              AND tce.case_id = tcm.case_id
2158              AND tcp.drug_type = 1
2159              AND nvl(tcp.product_id, tcp.pat_exposure) > 0
2160              AND tcm.case_num = src_case_num;
2161  
2162          v_index             PLS_INTEGER := 0;
2163          TYPE v_case_event_assess_tab IS
2164              TABLE OF tcase_event_assess%rowtype INDEX BY PLS_INTEGER;
2165          v_case_event_assess v_case_event_assess_tab;
2166          s_det_causality     s_producteventlevel.company_causality%TYPE;
2167          s_rpt_causality     s_producteventlevel.reported_causality%TYPE;
2168          s_listedness        s_producteventlevel.listedness%TYPE;
2169          l_tgt_lic_id        NUMBER;
2170      BEGIN
2171          FOR v_cau IN c_case_event_assess_cau LOOP
2172              v_index := v_index + 1;
2173              BEGIN
2174                  SELECT
2175                      company_causality,
2176                      reported_causality
2177                  INTO
2178                      s_det_causality,
2179                      s_rpt_causality
2180                  FROM
2181                      s_producteventlevel
2182                  WHERE
2183                          prod_seq_num = v_cau.s_prod_seq_num
2184                      AND event_seq_num = v_cau.s_event_seq_num
2185                      AND case_number = v_cau.case_num
2186                      AND listedness IS NULL
2187                      AND ( company_causality || reported_causality IS NOT NULL );
2188  
2189              EXCEPTION
2190                  WHEN OTHERS THEN
2191                      s_det_causality := NULL;
2192                      s_rpt_causality := NULL;
2193                      s_listedness := NULL;
2194              END;
2195  
2196              v_case_event_assess(v_index).case_id := pi_tcase_id;
2197              v_case_event_assess(v_index).event_seq_num := v_cau.event_seq_num;
2198              v_case_event_assess(v_index).prod_seq_num := v_cau.prod_seq_num;
2199              v_case_event_assess(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_EVENT_ASSESS', 'SEQ_NUM');
2200              v_case_event_assess(v_index).updated := pkg_mg_util.f_mg_key_val('Migration Date');
2201              v_case_event_assess(v_index).rpt_causality_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Causality', s_rpt_causality);
2202  
2203              v_case_event_assess(v_index).det_causality_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Causality', s_det_causality);
2204  
2205              IF v_case_event_assess(v_index).rpt_causality_id IS NOT NULL THEN
2206                  v_case_event_assess(v_index).rpt_source_id := pkg_mg_util.f_mg_key_val('Reported Source Causality');
2207                  v_case_event_assess(v_index).rpt_method_id := pkg_mg_util.f_mg_key_val('Causality Method');
2208              END IF;
2209  
2210              IF v_case_event_assess(v_index).det_causality_id IS NOT NULL THEN
2211                  v_case_event_assess(v_index).det_source_id := pkg_mg_util.f_mg_key_val('Determined Source Causality');
2212                  v_case_event_assess(v_index).det_method_id := pkg_mg_util.f_mg_key_val('Causality Method');
2213              END IF;
2214  
2215              v_case_event_assess(v_index).prt_source_id := NULL;
2216              v_case_event_assess(v_index).prt_method_id := NULL;
2217              v_case_event_assess(v_index).listed_justify := NULL;
2218              v_case_event_assess(v_index).cause_justify := NULL;
2219              v_case_event_assess(v_index).lam_assessed := 0;
2220              v_case_event_assess(v_index).causality_assessment := NULL;
2221              v_case_event_assess(v_index).causality_score := NULL;
2222              v_case_event_assess(v_index).source_id := NULL;
2223              v_case_event_assess(v_index).prt_causality_id := NULL;
2224              v_case_event_assess(v_index).last_update_time := pkg_mg_util.f_mg_key_val('Migration Date');
2225              v_case_event_assess(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
2226              v_case_event_assess(v_index).revision := NULL;
2227              v_case_event_assess(v_index).datasheet_id := 0;--check cannot insert null into this
2228              v_case_event_assess(v_index).license_id := 0; --check cannot insert null into this
2229  
2230              --Listeddness Loop
2231              FOR v_lic IN (
2232                  SELECT
2233                      tlc.license_id,
2234                      tlc.datasheet_id,
2235                      lc.country
2236                  FROM
2237                      tlm_license      tlc,
2238                      tlm_lic_products tllp,
2239                      tlm_countries    lc
2240                  WHERE
2241                          tllp.license_id = tlc.license_id
2242                      AND tllp.product_id = nvl(v_cau.product_id, v_cau.pat_exposure)
2243                      AND lc.country_id = tlc.country_id
2244              ) LOOP
2245                  v_index := v_index + 1;
2246                  UPDATE s_producteventlevel spe
2247                  SET
2248                      lic_map_cmnt = NULL
2249                  WHERE
2250                          spe.case_number = v_cau.case_num
2251                      AND spe.prod_seq_num = v_cau.s_prod_seq_num
2252                      AND spe.event_seq_num = v_cau.s_event_seq_num
2253                      AND spe.listedness IS NOT NULL;
2254  
2255                  l_tgt_lic_id := NULL;
2256                  FOR v_list IN (
2257                      SELECT DISTINCT
2258                          suspect_product_trade_name,
2259                          license_number,
2260                          license_country,
2261                          listedness
2262                      FROM
2263                          s_producteventlevel spe
2264                      WHERE
2265                              spe.case_number = v_cau.case_num
2266                          AND spe.prod_seq_num = v_cau.s_prod_seq_num
2267                          AND spe.event_seq_num = v_cau.s_event_seq_num
2268                          AND spe.listedness IS NOT NULL
2269                  ) LOOP
2270                      l_tgt_lic_id := pkg_mg_util.f_get_tgt_lic_id(v_list.suspect_product_trade_name, v_list.license_number, v_list.license_country
2271                      , v_cau.s_prod_seq_num, v_cau.s_event_seq_num,
2272                                                                   v_lic.license_id);
2273  
2274                      IF l_tgt_lic_id = v_lic.license_id THEN
2275                          v_case_event_assess(v_index).det_listedness_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Listedness', v_list.listedness
2276                          );
2277  
2278                      END IF;
2279  
2280                      --EXIT WHEN v_case_event_assess(v_index).det_listedness_id > 0;
2281  
2282                      IF
2283                          l_tgt_lic_id IS NULL
2284                          AND v_list.license_country = v_lic.country
2285                      THEN
2286                          l_tgt_lic_id := v_lic.license_id;
2287                          v_case_event_assess(v_index).det_listedness_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Listedness', v_list.listedness
2288                          );
2289  
2290                      END IF;
2291  
2292                  END LOOP;
2293  
2294                  UPDATE s_producteventlevel spe
2295                  SET
2296                      lic_map_cmnt = 'Mapped to ' || l_tgt_lic_id
2297                  WHERE
2298                          spe.case_number = v_cau.case_num
2299                      AND spe.prod_seq_num = v_cau.s_prod_seq_num
2300                      AND spe.event_seq_num = v_cau.s_event_seq_num
2301                      AND spe.listedness IS NOT NULL;
2302  
2303                  v_case_event_assess(v_index).case_id := pi_tcase_id;
2304                  v_case_event_assess(v_index).event_seq_num := v_cau.event_seq_num;
2305                  v_case_event_assess(v_index).prod_seq_num := v_cau.prod_seq_num;
2306                  v_case_event_assess(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_EVENT_ASSESS', 'SEQ_NUM');
2307                  v_case_event_assess(v_index).updated := pkg_mg_util.f_mg_key_val('Migration Date');
2308                  v_case_event_assess(v_index).listed_justify := NULL;
2309                  v_case_event_assess(v_index).last_update_time := pkg_mg_util.f_mg_key_val('Migration Date');
2310                  v_case_event_assess(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
2311                  v_case_event_assess(v_index).revision := NULL;
2312                  v_case_event_assess(v_index).datasheet_id := nvl(v_lic.datasheet_id, 0);--check cannot insert null into this
2313                  v_case_event_assess(v_index).license_id := nvl(v_lic.license_id, 0);--check cannot insert null into this
2314                  v_case_event_assess(v_index).lam_assessed := 0;--check cannot insert null into this
2315              END LOOP;
2316  
2317          END LOOP;
2318  
2319          FOR i IN 1..v_index LOOP
2320              INSERT INTO tcase_event_assess VALUES v_case_event_assess ( i );
2321  
2322          END LOOP;
2323  
2324      EXCEPTION
2325          WHEN OTHERS THEN
2326              pkg_mg_util.p_mg_log_message(
2327                  pi_scase_num    => src_case_num,
2328                  pi_tcase_id     => pi_tcase_id,
2329                  pi_message_type => 'ERROR',
2330                  pi_message      => 'P_MG_CASE_EVENT_assess ' || dbms_utility.format_error_stack,
2331                  pi_thread_id    => NULL,
2332                  pi_date_time    => systimestamp
2333              );
2334  
2335              raise_application_error(-20001, sqlerrm);
2336      END p_mg_case_event_assess;
