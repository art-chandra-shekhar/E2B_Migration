SQL> @@../packages/02_PKG_MG_UTIL_Body.SQL
SQL> create or replace PACKAGE BODY pkg_mg_util AS
  2  
  3      PROCEDURE p_mg_log_message (
  4          pi_scase_num    IN VARCHAR2,
  5          pi_tcase_id     IN NUMBER,
  6          pi_message_type IN VARCHAR2,
  7          pi_message      IN CLOB,
  8          pi_thread_id    IN NUMBER DEFAULT NULL,
  9          pi_date_time    IN TIMESTAMP
 10      ) IS
 11      BEGIN
 12          INSERT INTO mg_case_error_log (
 13              scase_num,
 14              tcase_id,
 15              message_type,
 16              message,
 17              thread_id,
 18              date_and_time
 19          ) VALUES ( pi_scase_num,
 20                     pi_tcase_id,
 21                     pi_message_type,
 22                     pi_message,
 23                     pi_thread_id,
 24                     pi_date_time );
 25  
 26          COMMIT;
 27      EXCEPTION
 28          WHEN OTHERS THEN
 29         -- rollback;
 30             dbms_output.put_line('Failed to log error in P_MG_LOG_MESSAGE: ' || sqlerrm);
 31      END p_mg_log_message;
 32  
 33      FUNCTION f_mg_codelist_code (
 34          pi_cl_type         IN VARCHAR2,
 35          pi_cl_name         IN VARCHAR2,
 36          pi_scodelist_value IN VARCHAR2
 37      ) RETURN NUMBER IS
 38          v_is_numeric BOOLEAN;
 39          t_code       NUMBER;
 40      BEGIN
 41          IF pi_scodelist_value IS NULL THEN
 42              RETURN NULL;
 43          END IF;
 44          v_is_numeric := regexp_like(
 45              trim(pi_scodelist_value),
 46              '^\d+$'
 47          );
 48          IF
 49              pi_cl_type = 'E2B'
 50              AND v_is_numeric
 51          THEN
 52              SELECT
 53                  t_cl_code
 54              INTO t_code
 55              FROM
 56                  mg_codelist_map
 57              WHERE
 58                      s_cl_e2b_code = pi_scodelist_value
 59                  AND cl_name = pi_cl_name;
 60  
 61          ELSIF
 62              pi_cl_type = 'E2B'
 63              AND NOT v_is_numeric
 64          THEN
 65              SELECT
 66                  t_cl_code
 67              INTO t_code
 68              FROM
 69                  mg_codelist_map
 70              WHERE
 71                      s_cl_e2b_decode = pi_scodelist_value
 72                  AND cl_name = pi_cl_name;
 73  
 74          ELSIF v_is_numeric THEN
 75              SELECT
 76                  t_cl_code
 77              INTO t_code
 78              FROM
 79                  mg_codelist_map
 80              WHERE
 81                      s_cl_code = pi_scodelist_value
 82                  AND cl_name = pi_cl_name;
 83  
 84          ELSE
 85              SELECT
 86                  t_cl_code
 87              INTO t_code
 88              FROM
 89                  mg_codelist_map
 90              WHERE
 91                      s_cl_decode = pi_scodelist_value
 92                  AND cl_name = pi_cl_name;
 93  
 94          END IF;
 95  
 96          IF t_code IS NULL THEN
 97              pkg_mg_util.p_mg_log_message(
 98                  pi_scase_num    => g_scase_num,
 99                  pi_tcase_id     => g_tcase_id,
100                  pi_message_type => 'WARNING',
101                  pi_message      => 'Target code for source value'
102                                || pi_scodelist_value
103                                || ' of codelist name->'
104                                || pi_cl_name
105                                || ' not mapped in codelist map table',
106                  pi_thread_id    => NULL,
107                  pi_date_time    => systimestamp
108              );
109          END IF;
110  
111          RETURN t_code;
112      EXCEPTION
113          WHEN no_data_found THEN
114              pkg_mg_util.p_mg_log_message(
115                  pi_scase_num    => g_scase_num,
116                  pi_tcase_id     => g_tcase_id,
117                  pi_message_type => 'WARNING',
118                  pi_message      => 'Source Codelist Value '
119                                || pi_scodelist_value
120                                || ' of codelist name->'
121                                || pi_cl_name
122                                || ' not found in codelist map table',
123                  pi_thread_id    => NULL,
124                  pi_date_time    => systimestamp
125              );
126  
127              RETURN t_code;
128          WHEN too_many_rows THEN
129              t_code := NULL;
130              pkg_mg_util.p_mg_log_message(
131                  pi_scase_num    => g_scase_num,
132                  pi_tcase_id     => g_tcase_id,
133                  pi_message_type => 'WARNING',
134                  pi_message      => 'Source Codelist Value '
135                                || pi_scodelist_value
136                                || ' of codelist name->'
137                                || pi_cl_name
138                                || ' found multiple times in codelist map table',
139                  pi_thread_id    => NULL,
140                  pi_date_time    => systimestamp
141              );
142  
143              RETURN t_code;
144          WHEN OTHERS THEN
145              pkg_mg_util.p_mg_log_message(
146                  pi_scase_num    => g_scase_num,
147                  pi_tcase_id     => g_tcase_id,
148                  pi_message_type => 'ERROR',
149                  pi_message      => 'Error: IN F_MG_CODELIST_CODE: ' || sqlerrm,
150                  pi_thread_id    => NULL,
151                  pi_date_time    => systimestamp
152              );
153  
154              RAISE;
155      END f_mg_codelist_code;
156  
157      FUNCTION f_mg_seq_num (
158          pi_tab_name IN VARCHAR2,
159          pi_col_name IN VARCHAR2
160      ) RETURN NUMBER IS
161          v_seq_name tcmn_table_col_seq_relations.sequence_name%TYPE;
162          v_sql      CLOB;
163          v_seq_num  NUMBER := NULL;
164      BEGIN
165          EXECUTE IMMEDIATE 'SELECT SEQUENCE_NAME 
166           FROM TCMN_TABLE_COL_SEQ_RELATIONS 
167           WHERE TABLE_NAME = '''
168                            || pi_tab_name
169                            || ''' 
170             AND COLUMN_NAME = '''
171                            || pi_col_name
172                            || ''''
173          INTO v_seq_name;
174          v_sql := 'SELECT ARGUS_APP.'
175                   || v_seq_name
176                   || '.NEXTVAL FROM dual';
177          EXECUTE IMMEDIATE v_sql
178          INTO v_seq_num;
179          RETURN v_seq_num;
180      EXCEPTION
181          WHEN no_data_found THEN
182              pkg_mg_util.p_mg_log_message(
183                  pi_scase_num    => g_scase_num,
184                  pi_tcase_id     => g_tcase_id,
185                  pi_message_type => 'WARNING',
186                  pi_message      => 'NO SEQUENCE NAME FOUND FOR THE REQUIRED SEQUENCE IN TCMN_TABLE_COL_SEQ_RELATIONS TABLE ' || sqlerrm
187                  ,
188                  pi_thread_id    => NULL,
189                  pi_date_time    => systimestamp
190              );
191  
192              RETURN v_seq_num;
193          WHEN too_many_rows THEN
194              pkg_mg_util.p_mg_log_message(
195                  pi_scase_num    => g_scase_num,
196                  pi_tcase_id     => g_tcase_id,
197                  pi_message_type => 'WARNING',
198                  pi_message      => 'MULTIPLE NMAES FOUND FOR A REQUIRED SEQUENCE IN TCMN_TABLE_COL_SEQ_RELATIONS TABLE' || sqlerrm,
199                  pi_thread_id    => NULL,
200                  pi_date_time    => systimestamp
201              );
202  
203              RETURN v_seq_num;
204          WHEN OTHERS THEN
205              pkg_mg_util.p_mg_log_message(
206                  pi_scase_num    => g_scase_num,
207                  pi_tcase_id     => g_tcase_id,
208                  pi_message_type => 'ERROR',
209                  pi_message      => 'Error: IN F_MG_SEQ_NUM: ' || sqlerrm,
210                  pi_thread_id    => NULL,
211                  pi_date_time    => systimestamp
212              );
213      END f_mg_seq_num;
214  
215      PROCEDURE p_mg_update_key_val IS
216  
217          CURSOR cur IS
218          SELECT
219              key,
220              sql_query
221          FROM
222              mg_case_const_val;
223  
224          v_sql   mg_case_const_val.sql_query%TYPE;
225          v_value mg_case_const_val.value%TYPE;
226      BEGIN
227          FOR rec IN cur LOOP
228          begin
229              v_sql := rec.sql_query;
230              EXECUTE IMMEDIATE v_sql
231              INTO v_value;
232              EXECUTE IMMEDIATE 'UPDATE MG_CASE_CONST_VAL 
233     SET VALUE = '''
234                                || v_value
235                                || ''' 
236     WHERE KEY = '''
237                                || rec.key
238                                || '''';
239        EXCEPTION
240          WHEN OTHERS THEN
241              pkg_mg_util.p_mg_log_message(
242                  pi_scase_num    => g_scase_num,
243                  pi_tcase_id     => g_tcase_id,
244                  pi_message_type => 'ERROR',
245                  pi_message      => 'Error: IN P_MG_UPDATE_KEY_VAL ' ||rec.key||', '|| sqlerrm,
246                  pi_thread_id    => NULL,
247                  pi_date_time    => systimestamp
248              );
249              end;
250  
251          END LOOP;
252      EXCEPTION
253          WHEN OTHERS THEN
254              pkg_mg_util.p_mg_log_message(
255                  pi_scase_num    => g_scase_num,
256                  pi_tcase_id     => g_tcase_id,
257                  pi_message_type => 'ERROR',
258                  pi_message      => 'Error: IN P_MG_UPDATE_KEY_VAL ' || sqlerrm,
259                  pi_thread_id    => NULL,
