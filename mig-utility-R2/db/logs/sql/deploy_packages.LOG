751  FUNCTION F_GET_DRUG_ID (
752      PI_drugcharacterization      IN VARCHAR2,
753      PI_obtaindrugcountry         IN VARCHAR2,
754      PI_drugadditional            IN VARCHAR2,
755      PI_drugauthorizationnumb     IN VARCHAR2,
756      PI_drugauthorizationholder   IN VARCHAR2,
757      PI_actiondrug                IN VARCHAR2,
758      PI_drugcumulativedosageunit  IN VARCHAR2,
759      PI_drugauthorizationcountry  IN VARCHAR2,
760      PI_drugcumulativedosagenum   IN VARCHAR2,
761      PI_case_num                  IN VARCHAR2,
762      PI_medicinalproduct          IN VARCHAR2,
763      PI_drugstartperiod           IN VARCHAR2
764  ) RETURN NUMBER
765  IS
766  V_DRUG_ID NUMBER:=NULL;
767  BEGIN
768  
769  BEGIN
770  SELECT drug_seq
771  INTO v_drug_id
772  FROM s_drug sd
773  WHERE (sd.drugcharacterization = PI_drugcharacterization
774         OR PI_drugcharacterization IS NULL)
775  
776    AND (UPPER(TRIM(sd.obtaindrugcountry)) =
777         UPPER(TRIM(PI_obtaindrugcountry))
778         OR PI_obtaindrugcountry IS NULL)
779  
780    AND (sd.drugadditional = PI_drugadditional
781         OR PI_drugadditional IS NULL)
782  
783    AND (sd.drugauthorizationnumb = PI_drugauthorizationnumb
784         OR PI_drugauthorizationnumb IS NULL)
785  
786    AND (UPPER(TRIM(sd.drugauthorizationholder)) =
787         UPPER(TRIM(PI_drugauthorizationholder))
788         OR PI_drugauthorizationholder IS NULL)
789  
790    AND (sd.actiondrug = PI_actiondrug
791         OR PI_actiondrug IS NULL)
792  
793    AND (sd.drugcumulativedosageunit = PI_drugcumulativedosageunit
794         OR PI_drugcumulativedosageunit IS NULL)
795  
796    AND (UPPER(TRIM(sd.drugauthorizationcountry)) =
797         UPPER(TRIM(PI_drugauthorizationcountry))
798         OR PI_drugauthorizationcountry IS NULL)
799  
800    AND (sd.drugcumulativedosagenumb = PI_drugcumulativedosagenum
801         OR PI_drugcumulativedosagenum IS NULL)
802  
803    AND (UPPER(TRIM(sd.case_number)) =
804         UPPER(TRIM(PI_case_num))
805         OR PI_case_num IS NULL)
806  
807    AND (UPPER(TRIM(sd.medicinalproduct)) =
808         UPPER(TRIM(PI_medicinalproduct))
809         OR PI_medicinalproduct IS NULL)
810  
811    AND (sd.drugstartperiod = PI_drugstartperiod
812         OR PI_drugstartperiod IS NULL);
813  
814  
815      RETURN v_drug_id;
816  EXCEPTION 
817   WHEN NO_DATA_FOUND THEN
818   pkg_mg_util.p_mg_log_message(
819                  pi_scase_num     => pkg_mg_util.g_scase_num,
820                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
821                  pi_message_type => 'ERROR',
822                  pi_message      => 'DRUG ID not found for case_num:'||pi_case_num||' and medicinal product:'||PI_medicinalproduct,
823                  pi_thread_id    => NULL,
824                  pi_date_time    => systimestamp
825              );
826              RETURN v_drug_id;
827  WHEN TOO_MANY_ROWS THEN
828  SELECT drug_seq
829  INTO v_drug_id
830  FROM s_drug sd
831  WHERE (sd.drugcharacterization = PI_drugcharacterization
832         OR PI_drugcharacterization IS NULL)
833  
834    AND (UPPER(TRIM(sd.obtaindrugcountry)) =
835         UPPER(TRIM(PI_obtaindrugcountry))
836         OR PI_obtaindrugcountry IS NULL)
837  
838    AND (sd.drugadditional = PI_drugadditional
839         OR PI_drugadditional IS NULL)
840  
841    AND (sd.drugauthorizationnumb = PI_drugauthorizationnumb
842         OR PI_drugauthorizationnumb IS NULL)
843  
844    AND (UPPER(TRIM(sd.drugauthorizationholder)) =
845         UPPER(TRIM(PI_drugauthorizationholder))
846         OR PI_drugauthorizationholder IS NULL)
847  
848    AND (sd.actiondrug = PI_actiondrug
849         OR PI_actiondrug IS NULL)
850  
851    AND (sd.drugcumulativedosageunit = PI_drugcumulativedosageunit
852         OR PI_drugcumulativedosageunit IS NULL)
853  
854    AND (UPPER(TRIM(sd.drugauthorizationcountry)) =
855         UPPER(TRIM(PI_drugauthorizationcountry))
856         OR PI_drugauthorizationcountry IS NULL)
857  
858    AND (sd.drugcumulativedosagenumb = PI_drugcumulativedosagenum
859         OR PI_drugcumulativedosagenum IS NULL)
860  
861    AND (UPPER(TRIM(sd.case_number)) =
862         UPPER(TRIM(PI_case_num))
863         OR PI_case_num IS NULL)
864  
865    AND (UPPER(TRIM(sd.medicinalproduct)) =
866         UPPER(TRIM(PI_medicinalproduct))
867         OR PI_medicinalproduct IS NULL)
868  
869    AND (sd.drugstartperiod = PI_drugstartperiod
870         OR PI_drugstartperiod IS NULL)
871   AND ROWNUM<=1 ORDER BY DRUG_SEQ ASC ;
872        RETURN v_drug_id;
873  END;
874  EXCEPTION 
875  WHEN OTHERS THEN
876   pkg_mg_util.p_mg_log_message(
877                  pi_scase_num     => pkg_mg_util.g_scase_num,
878                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
879                  pi_message_type => 'ERROR',
880                  pi_message      => 'Error in function: F_GET_DRUG_ID'|| sqlerrm,
881                  pi_thread_id    => NULL,
882                  pi_date_time    => systimestamp
883              );
884              return null;
885  END F_GET_DRUG_ID;
