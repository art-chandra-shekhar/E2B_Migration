3146          l_sfup              NUMBER := 0;
3147      BEGIN
3148         l_enterprise_id :=pkg_mg_util.f_mg_key_val('Enterprise Id');
3149          l_seq_num := pkg_mg_util.f_mg_seq_num('CASE_ROUTING', 'SEQ_NUM');
3150  
3151           SELECT
3152              state_id,
3153              last_state_id
3154          INTO
3155              l_to_state_id,
3156             l_fr_state_id
3157          FROM
3158              tcase_master
3159          WHERE
3160              case_id = pi_tcase_id;
3161  
3162          INSERT INTO tcase_routing (
3163              case_id,
3164              case_status,--cnf case status
3165              comment_txt,
3166              enterprise_id,
3167              followup_num,
3168              fr_state_id,
3169              justification_id,
3170              last_update_time,
3171              report_scheduling,
3172              route_date,
3173              s_followup_num,
3174              seq_num,
3175              sort_id,
3176              to_state_id,
3177              user_id,
3178              workflow_seq_num
3179          ) VALUES ( pi_tcase_id,
3180                     3,
3181                     l_comment_txt,
3182                     l_enterprise_id,
3183                     NULL,
3184                     l_fr_state_id,
3185                     NULL,
3186                     pkg_mg_util.f_mg_key_val('Migration Date'),
3187                     l_report_scheduling,
3188                     pkg_mg_util.f_mg_key_val('Migration Date'),
3189                     NULL,
3190                     l_seq_num,
3191                     l_sort_id,
3192                     l_to_state_id,
3193                     pkg_mg_util.f_mg_key_val('Migration User Id'),
3194                     NULL );
3195  
3196                         EXCEPTION
3197          WHEN OTHERS THEN
3198              pkg_mg_util.p_mg_log_message(
3199                pi_scase_num    => src_case_num,
3200                  pi_tcase_id     => pi_tcase_id,
3201                  pi_message_type => 'ERROR',
3202                  pi_message      => 'P_MG_CASE_ROUTING' || dbms_utility.format_error_stack,
3203                  pi_thread_id    => NULL,
3204                  pi_date_time    => systimestamp
3205              );
3206  
3207              raise_application_error(-20001, sqlerrm);
3208      END p_mg_case_routing;
