1035      PROCEDURE p_mg_case_event (
1036          src_case_num IN VARCHAR2,
1037          pi_tcase_id  IN NUMBER
1038      ) IS
1039  
1040          CURSOR c_case_event IS
1041          SELECT
1042              sr.*,
1043              cel.preferred_term,
1044              cel.reported_term,
1045              cel.event_outcome,
1046              cel.event_seriousness,
1047              cel.death,
1048              cel.hospitalization,
1049              cel.congenital_anomaly,
1050              cel.life_threatening,
1051              cel.disabling,
1052              cel.other,
1053              cel.medically_significant,
1054              cel.event_seq_num
1055          FROM
1056              s_reaction      sr
1057              LEFT JOIN s_caseeventlevel cel ON cel.case_number = sr.case_number
1058                                                  AND cel.event_seq_num = sr.evt_seq_num
1059          WHERE
1060              sr.case_number = src_case_num
1061              order by cel.event_seq_num;
1062  
1063          TYPE t_case_event_tab IS
1064              TABLE OF tcase_event%rowtype INDEX BY PLS_INTEGER;
1065          v_case_event t_case_event_tab;
1066          v_index      PLS_INTEGER := 0;
1067          v_cnt_seriousness number:=null;
1068      BEGIN
1069          FOR v_row IN c_case_event LOOP
1070              v_index := v_index + 1;
1071  
1072              v_case_event(v_index).case_id := pi_tcase_id;
1073              v_case_event(v_index).sort_id := v_index;
1074              v_case_event(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_EVENT', 'SEQ_NUM');
1075              v_case_event(v_index).desc_reptd := v_row.primarysourcereaction; 
1076          -- Direct : REACTIONS.
1077              v_case_event(v_index).desc_coded := v_row.reactionmeddrapt;
1078              v_case_event(v_index).duration := v_row.reactionduration;
1079              v_case_event(v_index).duration_unit_e2b := v_row.reactiondurationunit;
1080              v_case_event(v_index).duration_seconds := pkg_mg_util.f_convert_to_seconds(v_row.reactionduration, v_row.reactiondurationunit
1081              );
1082  
1083              v_case_event(v_index).onset_delay := v_row.reactionfirsttime;
1084              v_case_event(v_index).onset_delay_unit_e2b := v_row.reactionfirsttimeunit;
1085              v_case_event(v_index).onset_latency := v_row.reactionlasttime;
1086              IF v_row.event_outcome IS NOT NULL THEN
1087                  v_case_event(v_index).evt_outcome_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Event Outcome', v_row.event_outcome
1088                  );
1089              ELSE
1090                  v_case_event(v_index).evt_outcome_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Event Outcome', v_row.reactionoutcome)
1091                  ;
1092              END IF;
1093  
1094           --   v_case_event(v_index).rpt_serious := pkg_mg_util.f_mg_codelist_code('E2B', 'TERMHIGHLIGHTED', v_row.termhighlighted);--confirm mapping
1095  
1096              v_case_event(v_index).sc_death :=
1097                  CASE
1098                      WHEN v_row.death = 'Yes' THEN
1099                          1
1100                      ELSE 0
1101                  END;
1102  
1103              v_case_event(v_index).sc_hosp :=
1104                  CASE
1105                      WHEN v_row.hospitalization = 'Yes' THEN
1106                          1
1107                      ELSE 0
1108                  END;
1109  
1110              v_case_event(v_index).sc_cong_anom :=
1111                  CASE
1112                      WHEN v_row.congenital_anomaly = 'Yes' THEN
1113                          1
1114                      ELSE 0
1115                  END;
1116  
1117              v_case_event(v_index).sc_threat :=
1118                  CASE
1119                      WHEN v_row.life_threatening = 'Yes' THEN
1120                          1
1121                      ELSE 0
1122                  END;
1123  
1124              v_case_event(v_index).sc_disable :=
1125                  CASE
1126                      WHEN v_row.disabling = 'Yes' THEN
1127                          1
1128                      ELSE 0
1129                  END;
1130  
1131              v_case_event(v_index).sc_other :=
1132                  CASE
1133                      WHEN v_row.other = 'Yes' THEN
1134                          1
1135                      ELSE 0
1136                  END;
1137  
1138              v_case_event(v_index).sc_death :=
1139                  CASE
1140                      WHEN v_row.death = 'Yes' THEN
1141                          1
1142                      ELSE 0
1143                  END;
1144  
1145              v_case_event(v_index).seriousness :=
1146                  CASE
1147                      WHEN v_row.event_seriousness = 'Yes' THEN
1148                          1
1149                      ELSE 0
1150                  END;
1151  
1152              v_case_event(v_index).med_serious :=
1153                  CASE
1154                      WHEN v_row.death = 'Yes' THEN
1155                          1
1156                      ELSE 0
1157                  END;
1158  
1159              v_case_event(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1160              pkg_mg_buss_rules.p_meddra_map_br001('Event',
1161                                                   v_row.reactionmeddrallt,
1162                                                   v_row.preferred_term,
1163                                                   v_row.reported_term,
1164                                                   v_case_event(v_index).inc_code,
1165                                                   v_case_event(v_index).inc_term,
1166                                                   v_case_event(v_index).art_code,
1167                                                   v_case_event(v_index).pref_term,
1168                                                   v_case_event(v_index).hlt_code,
1169                                                   v_case_event(v_index).hlt,
1170                                                   v_case_event(v_index).hlgt_code,
1171                                                   v_case_event(v_index).hlgt,
1172                                                   v_case_event(v_index).soc_code,
1173                                                   v_case_event(v_index).body_sys,
1174                                                   v_case_event(v_index).code_status,
1175                                                   v_case_event(v_index).dict_id);
1176  
1177              pkg_mg_buss_rules.p_get_partial_date('CASE_EVENT',
1178                                                   v_row.reactionstartdateformat,
1179                                                   v_row.reactionstartdate,
1180                                                   v_case_event(v_index).onset,
1181                                                   v_case_event(v_index).onset_res,
1182                                                   v_case_event(v_index).onset_date_partial);
1183  
1184              pkg_mg_buss_rules.p_get_partial_date('CASE_EVENT',
1185                                                   v_row.reactionenddateformat,
1186                                                   v_row.reactionenddate,
1187                                                   v_case_event(v_index).stop_date,
1188                                                   v_case_event(v_index).stop_date_res,
1189                                                   v_case_event(v_index).stop_date_partial);
1190  
1191              pkg_mg_util.p_insert_seq_mapping('S_REACTIONS',
1192                                               'CASE_EVENT',
1193                                               'REACTION_ID',
1194                                               'SEQ_NUM',
1195                                               v_row.reaction_seq,
1196                                               v_case_event(v_index).seq_num);
1197  
1198              pkg_mg_util.p_insert_seq_mapping('S_CASEEVENTLEVEL',
1199                                               'CASE_EVENT',
1200                                               'EVENT_SEQ_NUM',
1201                                               'SEQ_NUM',
1202                                               v_row.event_seq_num,
1203                                               v_case_event(v_index).seq_num);
1204  /*changes*/
1205              v_case_event(v_index).study_dropped := -1;
1206              v_case_event(v_index).study_related := -1;
1207              v_case_event(v_index).diagnosis := 1;
1208              v_case_event(v_index).delay_minutes := pkg_mg_util.f_convert_to_seconds(v_row.reactionfirsttime, v_row.reactionfirsttimeunit
1209              );
1210  
1211              v_case_event(v_index).onset_delay_seconds := pkg_mg_util.f_convert_to_seconds(v_row.reactionfirsttime, v_row.reactionfirsttimeunit
1212              );
1213  
1214              v_case_event(v_index).onset_latency_seconds := pkg_mg_util.f_convert_to_seconds(v_row.reactionlasttime, v_row.reactionlasttimeunit
1215              );
1216  
1217              v_case_event(v_index).onset_latency_unit_e2b := pkg_mg_util.f_convert_to_seconds(v_row.reactionlasttime, v_row.reactionlasttimeunit
1218              );
1219  
1220              v_case_event(v_index).onset_minutes := pkg_mg_util.f_convert_to_seconds(v_row.reactionlasttime, v_row.reactionlasttimeunit
1221              );
1222  
1223          END LOOP;
1224  
1225          FOR i IN 1..v_index LOOP
1226              INSERT INTO tcase_event VALUES v_case_event ( i );
1227  
1228          END LOOP;
1229  
1230  select count(1) 
1231  into v_cnt_seriousness
1232  from tcase_event 
1233  where case_id=pi_tcase_id 
1234  and deleted is null 
1235  and (SERIOUSNESS=1 or SC_DEATH = 1 
1236  OR SC_HOSP = 1 
1237  OR SC_CONG_ANOM = 1 
1238  OR SC_THREAT = 1 
1239  OR SC_DISABLE = 1 
1240  OR SC_INT_REQ = 1 
1241  OR SC_OTHER = 1);
1242  
1243  UPDATE tcase_master tcm
1244  SET tcm.SERIOUSNESS = 
1245      CASE 
1246          WHEN v_cnt_seriousness > 0 THEN 1
1247          ELSE 0
1248      END
1249  WHERE case_id = pi_tcase_id;
1250      EXCEPTION
1251          WHEN OTHERS THEN
1252              pkg_mg_util.p_mg_log_message(
1253                  pi_scase_num    => src_case_num,
1254                  pi_tcase_id     => pi_tcase_id,
1255                  pi_message_type => 'ERROR',
1256                  pi_message      => 'P_MG_CASE_EVENT' || dbms_utility.format_error_stack,
1257                  pi_thread_id    => NULL,
1258                  pi_date_time    => systimestamp
1259              );
1260  
1261              raise_application_error(-20001, sqlerrm);
1262      END p_mg_case_event;
