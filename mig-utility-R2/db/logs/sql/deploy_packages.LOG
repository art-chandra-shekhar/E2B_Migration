417      PROCEDURE p_mg_case_pat_info (
418          src_case_num IN VARCHAR2,
419          pi_tcase_id  IN NUMBER
420      ) IS
421  
422          CURSOR c_patient IS
423          SELECT
424              p.patient_seq,
425              p.patientagegroup,
426              p.patientonsetageunit,
427              p.patientsex,
428              p.patientmedicalhistorytext,
429              p.patientonsetage,
430              p.patientbirthdate,
431              p.patientbirthdateformat,
432              p.patientheight,
433              p.patientinvestigationnumb,
434              p.patientinitial,
435              p.patientweight
436          FROM
437              s_patient p
438          WHERE
439              p.case_number = src_case_num;
440  
441          TYPE t_case_pat_info_tab IS
442              TABLE OF tcase_pat_info%rowtype INDEX BY PLS_INTEGER;
443          v_case_pat_info t_case_pat_info_tab;
444          v_index         PLS_INTEGER := 0;
445      BEGIN
446          FOR v_row IN c_patient LOOP
447              v_index := v_index + 1;
448              v_case_pat_info(v_index).case_id := pi_tcase_id;
449              v_case_pat_info(v_index).case_id := pi_tcase_id;
450              v_case_pat_info(v_index).age_group_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Age Groups', v_row.patientagegroup);
451  
452              v_case_pat_info(v_index).age_unit_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Age Units', v_row.patientonsetageunit);
453  
454              v_case_pat_info(v_index).gender_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Gender', v_row.patientsex);
455  
456              v_case_pat_info(v_index).notes := v_row.patientmedicalhistorytext;
457              v_case_pat_info(v_index).pat_age := v_row.patientonsetage;
458              v_case_pat_info(v_index).pat_id := v_row.patientinvestigationnumb;
459              v_case_pat_info(v_index).pat_initials := v_row.patientinitial;
460              v_case_pat_info(v_index).pat_height_cm := v_row.patientheight;
461              v_case_pat_info(v_index).pat_weight_kg := v_row.patientweight;
462              v_case_pat_info(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
463              v_case_pat_info(v_index).PAT_SUBJ_NUM:=v_row.PATIENTINVESTIGATIONNUMB;
464              pkg_mg_buss_rules.p_get_partial_date('CASE_PAT_INFO',
465                                                   v_row.patientbirthdateformat,
466                                                   v_row.patientbirthdate,
467                                                   v_case_pat_info(v_index).pat_dob,
468                                                   v_case_pat_info(v_index).pat_dob_res,
469                                                   v_case_pat_info(v_index).pat_dob_partial);
470  
471              v_case_pat_info(v_index).pat_height_in :=
472                  CASE
473                      WHEN v_row.patientheight IS NOT NULL THEN
474                          round(v_row.patientheight / 2.54, 2)
475                      ELSE NULL
476                  END;
477  
478              v_case_pat_info(v_index).pat_weight_lbs :=
479                  CASE
480                      WHEN v_row.patientweight IS NOT NULL THEN
481                          round(v_row.patientweight * 2.20462, 2)
482                      ELSE NULL
483                  END;
484  
485          END LOOP;
486  
487          FOR i IN 1..v_index LOOP
488              INSERT INTO tcase_pat_info VALUES v_case_pat_info ( i );
489  
490          END LOOP;
491  
492      EXCEPTION
493          WHEN OTHERS THEN
494              pkg_mg_util.p_mg_log_message(
495                  pi_scase_num    => src_case_num,
496                  pi_tcase_id     => pi_tcase_id,
497                  pi_message_type => 'ERROR',
498                  pi_message      => 'P_MG_CASE_PAT_INFO ' || dbms_utility.format_error_stack,
499                  pi_thread_id    => NULL,
500                  pi_date_time    => systimestamp
501              );
502  
503              raise_application_error(-20001, sqlerrm);
504      END p_mg_case_pat_info;
