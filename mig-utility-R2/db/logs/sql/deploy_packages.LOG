556  PROCEDURE P_MG_STUDY_MAPPING(
557  pi_studyname IN VARCHAR2,
558  pi_sponsorstudynumb IN VARCHAR2,
559                    pi_observestudytype IN VARCHAR2,
560   po_cohort_id         OUT NUMBER,
561      po_study_key         OUT NUMBER,
562      po_blind_name        OUT VARCHAR2,
563      po_blind_name_j      OUT VARCHAR2,
564      po_study_type        OUT NUMBER,
565      po_study_num         OUT VARCHAR2,
566      po_study_num_j   OUT VARCHAR2,
567      po_protocol_num      OUT VARCHAR2,
568      po_classification_id OUT NUMBER,
569      po_protocol_id       OUT NUMBER,
570      po_study_desc        OUT CLOB,
571      po_study_desc_j      OUT CLOB,
572      po_dev_phase_id      OUT NUMBER
573  )
574  IS
575  BEGIN
576  
577  
578  BEGIN
579  
580  
581  select DISTINCT tgt_study_key, tgt_cohort_id
582  INTO po_study_key,po_cohort_id
583  from MG_STUDY_PRODUCT_MAPPING rec
584  WHERE upper(trim(rec.STUDYNAME))||upper(trim(rec.SPONSORSTUDYNUMB))||rec.OBSERVESTUDYTYPE
585  =upper(trim(pi_studyname))||upper(trim(pi_sponsorstudynumb))||pi_observestudytype;
586  
587  EXCEPTION
588  WHEN OTHERS THEN 
589  po_study_key:=NULL;
590  po_cohort_id:=NULL;
591  --ADD WARNING
592  END;
593  
594  
595  
596  
597  SELECT distinct
598      TLSC.study_key,
599      TLS.study_num,
600      TLS.study_num_j,
601      TLSC.cohort_id,
602      TLSC.blind_name,
603      TLSC.blind_name_j,
604      TLSC.study_type_id,
605      TLS.protocol_num,
606      TLS.id_protocol,
607      TLS.classification_id,
608      TLS.study_desc,
609      TLS.study_desc_j,
610      TLS.dev_phase_id
611  INTO 
612      po_study_key,
613      po_study_num,
614      po_study_num_j,
615      po_cohort_id,
616      po_blind_name,
617      po_blind_name_j,
618      po_study_type,
619      po_protocol_num,
620      po_protocol_id,
621      po_classification_id,
622      po_study_desc,
623      po_study_desc_j,
624      po_dev_phase_id
625  FROM tlm_studies tls
626  INNER JOIN tlm_study_cohorts tlsc 
627         ON tls.study_key = tlsc.study_key
628  WHERE tls.deleted IS NULL
629  AND tlsc.deleted IS NULL
630  and tls.study_key=po_study_key
631  and tlsc.cohort_id=po_cohort_id
632  --AND UPPER(TRIM(tls.study_num)) = UPPER(TRIM(pi_study_num))
633  --and TLSC.study_key=NVL(po_study_key,TLSC.study_key)
634  --and TLSC.cohort_id=NVL(po_cohort_id,TLSC.cohort_id)
635  ;
636  
637  EXCEPTION
638          WHEN no_data_found THEN
639              pkg_mg_util.p_mg_log_message(
640                  pi_scase_num    => pkg_mg_util.g_scase_num,
641                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
642                  pi_message_type => 'WARNING',
643                  pi_message      => 'Study  Mapping Not found for study Num-> '||upper(trim(pi_studyname))||upper(trim(pi_sponsorstudynumb))||pi_observestudytype,
644                  pi_thread_id    => NULL,
645                  pi_date_time    => systimestamp
646              );
647  po_study_key         := NULL;
648  po_study_num         := NULL;
649  po_study_num_j       := NULL;
650  po_cohort_id         := NULL;
651  po_blind_name        := NULL;
652  po_blind_name_j      := NULL;
653  po_study_type        := NULL;
654  po_protocol_num      := NULL;
655  po_protocol_id       := NULL;
656  po_classification_id := NULL;
657  po_study_desc        := NULL;
658  po_study_desc_j      := NULL;
659  po_dev_phase_id      := NULL;
660              WHEN too_many_rows THEN
661              pkg_mg_util.p_mg_log_message(
662                  pi_scase_num    => pkg_mg_util.g_scase_num,
663                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
664                  pi_message_type => 'WARNING',
665                  pi_message      => 'multiple records found in Study Mapping for Study Num->'||upper(trim(pi_studyname))||upper(trim(pi_sponsorstudynumb))||pi_observestudytype,
666                  pi_thread_id    => NULL,
667                  pi_date_time    => systimestamp
668              );
669               WHEN OTHERS THEN
670              pkg_mg_util.p_mg_log_message(
671                  pi_scase_num    => pkg_mg_util.g_scase_num,
672                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
673                  pi_message_type => 'ERROR',
674                  pi_message      => 'ERROR IN PROCEDURE:P_MG_STUDY_MAPPING :'||SQLERRM,
675                  pi_thread_id    => NULL,
676                  pi_date_time    => systimestamp
677              );
678              END P_MG_STUDY_MAPPING;
