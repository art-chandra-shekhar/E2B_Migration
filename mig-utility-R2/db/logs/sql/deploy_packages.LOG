SQL> create or replace PACKAGE BODY pkg_mg_migration IS
  2  
  3      PROCEDURE p_mg_case_master (
  4          src_case_num IN VARCHAR2,
  5          pi_tcase_id  IN NUMBER
  6      ) IS
  7  
  8          CURSOR c_case_master IS
  9          SELECT
 10              ssr.*,
 11              scl.report_type
 12          FROM
 13                   S_SAFETYREPORT ssr
 14              INNER JOIN s_caselevel scl ON ssr.case_number = scl.case_number
 15          WHERE
 16              ssr.case_number = src_case_num;
 17  
 18          v_index       PLS_INTEGER := 0;
 19          TYPE v_case_master_tab IS
 20              TABLE OF tcase_master%rowtype INDEX BY PLS_INTEGER;
 21          v_case_master v_case_master_tab;
 22      BEGIN
 23          FOR v_row IN c_case_master LOOP
 24              v_index := v_index + 1;
 25               v_case_master(v_index).rev:=0;
 26              v_case_master(v_index).case_id := pi_tcase_id;
 27              v_case_master(v_index).case_num := src_case_num;
 28              v_case_master(v_index).create_time := pkg_mg_util.f_mg_key_val('Migration Date');
 29              v_case_master(v_index).init_rept_date := pkg_mg_util.f_var_to_date('CASE_MASTER->INIT_REPT_DATE', v_row.receivedateformat
 30              , v_row.receivedate);
 31  
 32              v_case_master(v_index).user_id := pkg_mg_util.f_mg_key_val('Migration User Id');
 33              v_case_master(v_index).last_update_time := pkg_mg_util.f_mg_key_val('Migration Date');
 34              v_case_master(v_index).last_update_user_id := pkg_mg_util.f_mg_key_val('Migration User Id');
 35              v_case_master(v_index).followup_date := pkg_mg_util.f_var_to_date('CASE_MASTER->FOLLOWUP_DATE', v_row.receiptdateformat, v_row.receiptdate
 36              );
 37  
 38              v_case_master(v_index).owner_id := pkg_mg_util.f_mg_key_val('Migration User Id');
 39              v_case_master(v_index).country_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Countries', v_row.occurcountry);
 40  
 41              v_case_master(v_index).seriousness :=
 42                  CASE
 43                      WHEN v_row.serious = 1 THEN
 44                          1
 45                      ELSE 0
 46                  END;
 47  
 48              v_case_master(v_index).requires_followup := 0;
 49              v_case_master(v_index).rpt_type_id := pkg_mg_util.f_mg_codelist_code('Non_E2B', 'Report Type', v_row.report_type);
 50  
 51              v_case_master(v_index).sid := pkg_mg_util.f_mg_key_val('Database SID');
 52              v_case_master(v_index).e2b_ww_number := v_row.safetyreportid;
 53              v_case_master(v_index).medically_confirm :=
 54                  CASE
 55                      WHEN v_row.medicallyconfirm = 1 THEN
 56                          1
 57                      ELSE 0
 58                  END;
 59  
 60              v_case_master(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
 61              v_case_master(v_index).workflow_seq_num := NULL;
 62              v_case_master(v_index).last_workflow_seq_num := NULL;
 63              v_case_master(v_index).state_id := 2;
 64              v_case_master(v_index).last_state_id := NULL;--dont have case processing state in target cfg_workdflow states
 65              v_case_master(v_index).close_date := pkg_mg_util.f_mg_key_val('Migration Date');
 66               v_case_master(v_index).close_user_id := pkg_mg_util.f_mg_key_val('Migration User Id');
 67              v_case_master(v_index).initial_justification := NULL;
 68              v_case_master(v_index).lam_assess_done := 0;
 69              v_case_master(v_index).lock_status_id := 3;
 70              v_case_master(v_index).site_id := pkg_mg_util.f_mg_key_val('Site Id');
 71  
 72                 /*changes*/--27 Feb
 73  
 74              v_case_master(v_index).date_locked := pkg_mg_util.f_mg_key_val('Migration Date');
 75              v_case_master(v_index).seriousness :=
 76                  CASE
 77                      WHEN v_row.serious = 1 THEN
 78                          1
 79                      ELSE 0
 80                  END;
 81  
 82              v_case_master(v_index).close_notes := 'Migrated from Sebela'; --CNF IF IT HAS TO BE DEFAULT
 83              v_case_master(v_index).priority := 0;              ---default sn
 84              v_case_master(v_index).priority_assessment := 1;
 85              v_case_master(v_index).priority_date_assessed := pkg_mg_util.f_mg_key_val('Migration Date');
 86              v_case_master(v_index).priority_override := 1;
 87              v_case_master(v_index).report_scheduling := 0;
 88              v_case_master(v_index).susar := 0;
 89              v_case_master(v_index).assessment_needed := 0;
 90          END LOOP;
 91  
 92          FOR i IN 1..v_index LOOP
 93              INSERT INTO tcase_master VALUES v_case_master ( i );
 94  
 95          END LOOP;
 96  
 97      EXCEPTION
 98          WHEN OTHERS THEN
 99              pkg_mg_util.p_mg_log_message(
100                  pi_scase_num    => src_case_num,
101                  pi_tcase_id     => pi_tcase_id,
102                  pi_message_type => 'ERROR',
103                  pi_message      => 'P_MG_CASE_MASTER ' || dbms_utility.format_error_stack,
104                  pi_thread_id    => NULL,
105                  pi_date_time    => systimestamp
106              );
107  
108              raise_application_error(-20001, sqlerrm);
109      END p_mg_case_master;
