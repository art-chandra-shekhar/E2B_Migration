1309      PROCEDURE p_mg_case_product (
1310          src_case_num IN VARCHAR2,
1311          pi_tcase_id  IN NUMBER
1312      ) IS
1313  
1314          CURSOR c_case_product IS
1315          SELECT DISTINCT
1316              sd.drugcharacterization,
1317              sd.obtaindrugcountry,
1318              sd.drugadditional,
1319              sd.drugauthorizationnumb,
1320              sd.drugauthorizationholder,
1321              sd.actiondrug,
1322              sd.drugcumulativedosageunit,
1323              sd.drugauthorizationcountry,
1324              sd.drugcumulativedosagenumb,
1325              sd.case_number,
1326              sd.medicinalproduct,
1327              sd.drugstartperiod,
1328              sd.drugdosageform,
1329              sd.drug_seq_num,
1330              sclp.prod_seq_num,
1331              sclp.argus_display_order,
1332              sclp.suspect_drug_name,
1333              sclp.action_taken,
1334              sclp.dechallenge,
1335              sclp.rechallenge
1336          FROM
1337              s_drug             sd
1338              LEFT OUTER JOIN s_caseproductlevel sclp ON ( sd.case_number = sclp.case_number
1339                                                             AND upper(trim(sd.medicinalproduct)) = upper(trim(sclp.suspect_drug_name))
1340                                                             )
1341          WHERE
1342                  sd.case_number = src_case_num
1343              AND sd.drug_seq_num = sd.drug_seq_num
1344          ORDER BY
1345              sclp.argus_display_order,
1346              sd.drugcharacterization ASC;
1347  
1348          v_index              PLS_INTEGER := 0;
1349          TYPE v_case_product_tab IS
1350              TABLE OF tcase_product%rowtype INDEX BY PLS_INTEGER;
1351          v_case_product       v_case_product_tab;
1352  
1353      /*CASE_PROD_DRUGS*/
1354  
1355          TYPE v_case_prod_drugs_tab IS
1356              TABLE OF tcase_prod_drugs%rowtype INDEX BY PLS_INTEGER;
1357          v_case_prod_drugs    v_case_prod_drugs_tab;
1358  
1359      /*case_dose_regimens*/
1360  
1361          CURSOR c_case_dose_regimens (
1362              ci_drug_seq_num IN NUMBER
1363          ) IS
1364          SELECT
1365              *
1366          FROM
1367              s_drug sd2
1368          WHERE
1369                  sd2.case_number = src_case_num
1370              AND upper(trim(sd2.drug_seq_num)) = upper(trim(ci_drug_seq_num));
1371  
1372          v_index1             PLS_INTEGER := 0;
1373          TYPE v_case_dose_regimens_tab IS
1374              TABLE OF tcase_dose_regimens%rowtype INDEX BY PLS_INTEGER;
1375          v_case_dose_regimens v_case_dose_regimens_tab;
1376          v_generic_name       s_producteventlevel.suspect_product_generic_name%TYPE;
1377          l_product_id         NUMBER;
1378          s_drug_id            NUMBER := NULL;
1379          v_trade_name         tlm_license.trade_name%TYPE;
1380          v_trade_name_j       tlm_license.trade_name_j%TYPE;
1381          v_sus_check          NUMBER := 0;
1382          v_study_type         NUMBER := NULL;
1383          v_code_broken        NUMBER := NULL;
1384          l_study_key          NUMBER;
1385          l_cohort_id          NUMBER;
1386      BEGIN
1387          SELECT
1388              study_key,
1389              cohort_id,
1390              code_broken
1391          INTO
1392              l_study_key,
1393              l_cohort_id,
1394              v_code_broken
1395          FROM
1396              tcase_study
1397          WHERE
1398              case_id = pi_tcase_id;
1399  
1400          FOR v_row IN c_case_product LOOP
1401              v_index := v_index + 1;
1402              l_product_id := NULL;
1403              v_generic_name := NULL;
1404              s_drug_id := pkg_mg_util.f_get_drug_id(v_row.drugcharacterization, v_row.obtaindrugcountry, v_row.drugadditional, v_row.drugauthorizationnumb
1405              , v_row.drugauthorizationholder,
1406                                                     v_row.actiondrug, v_row.drugcumulativedosageunit, v_row.drugauthorizationcountry, v_row.drugcumulativedosagenumb
1407                                                     , v_row.case_number,
1408                                                     v_row.medicinalproduct, v_row.drugstartperiod);
1409  
1410              v_case_product(v_index).case_id := pi_tcase_id;
1411              v_case_product(v_index).seq_num := pkg_mg_util.f_mg_seq_num('CASE_PRODUCT', 'SEQ_NUM');
1412              v_case_product(v_index).drug_type := v_row.drugcharacterization;
1413              v_case_product(v_index).first_sus_prod :=
1414                  CASE
1415                      WHEN v_sus_check = 0 THEN
1416                          pkg_mg_util.f_get_firsr_sus_product(pi_tcase_id, src_case_num, v_row.suspect_drug_name, v_row.medicinalproduct
1417                          , v_row.argus_display_order)
1418                      ELSE 0
1419                  END;
1420  
1421              IF v_case_product(v_index).first_sus_prod = 1 THEN
1422                  v_sus_check := 1;
1423              END IF;
1424              v_case_product(v_index).sort_id := v_index;
1425              v_case_product(v_index).enterprise_id := pkg_mg_util.f_mg_key_val('Enterprise Id');
1426              BEGIN
1427                  SELECT DISTINCT
1428                      ( suspect_product_generic_name )
1429                  INTO v_generic_name
1430                  FROM
1431                      s_producteventlevel spe
1432                  WHERE
1433                          spe.prod_seq_num = v_row.prod_seq_num
1434                      AND spe.case_number = v_row.case_number
1435                      AND suspect_product_generic_name IS NOT NULL;
1436  
1437              EXCEPTION
1438                  WHEN no_data_found THEN
1439                      v_generic_name := NULL;
1440              END;
1441  
1442  
1443  
1444  --checking if a product is study product or not LOGIC START FROM HERE.
1445              IF l_study_key IS NOT NULL THEN
1446                  pkg_mg_buss_rules.p_get_tgt_study_prod_id(v_row.drug_seq_num,
1447                                                            l_study_key,
1448                                                            l_cohort_id,
1449                                                            v_row.medicinalproduct,
1450                                                            v_row.drugdosageform,
1451                                                            V_ROW.drugauthorizationNUMB,
1452                                                            V_ROW.drugauthorizationcountry,
1453                                                            v_row.suspect_drug_name,
1454                                                            v_generic_name,
1455                                                            l_product_id,
1456                                                            v_case_product(v_index).prod_lic_id);
1457              END IF;
1458  
1459   --Product is a study Drug           
1460              IF l_product_id IS NOT NULL THEN
1461                  v_case_product(v_index).co_drug_code := 'Study Drug';
1462              ELSE
1463                  v_case_product(v_index).co_drug_code := '';
1464                  pkg_mg_buss_rules.p_get_tgt_prod_id(v_row.suspect_drug_name,
1465                                                      v_row.medicinalproduct,
1466                                                      v_row.drugdosageform,
1467                                                      v_row.drugauthorizationcountry,
1468                                                      v_row.drugauthorizationnumb,
1469                                                      v_generic_name,
1470                                                      l_product_id,
1471                                                      v_case_product(v_index).prod_lic_id);
1472  
1473              END IF;
1474  
1475              IF l_product_id IS NOT NULL THEN
1476                  v_case_product(v_index).selected_view := 1;
1477                  SELECT
1478                      formulation_id,
1479                      concentration,
1480                      conc_unit_id,
1481                      family_id
1482                  INTO
1483                      v_case_prod_drugs(v_index).formulation_id,
1484                      v_case_prod_drugs(v_index).concentration,
1485                      v_case_prod_drugs(v_index).conc_units_id,
1486                      v_case_product(v_index).family_id
1487                  FROM
1488                      tlm_product
1489                  WHERE
1490                          product_id = l_product_id
1491                      AND enterprise_id = pkg_mg_util.f_mg_key_val('Enterprise Id');
1492  
1493              END IF;
1494  
1495              dbms_output.put_line('N4>' || l_product_id);
1496              IF l_product_id IS NOT NULL THEN
1497                  IF v_case_product(v_index).co_drug_code = 'Study Drug' THEN
1498                      IF v_code_broken = 0 AND UPPER(v_row.medicinalproduct)  LIKE '%BLINDED%' THEN ---Blinded STUDY
1499  
1500                          v_case_product(v_index).product_id := l_product_id;
1501                          v_case_product(v_index).pat_exposure := 0;
1502                          v_case_product(v_index).prod_reptd := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1503  
1504                          SELECT
1505                              nvl(blind_name, study_num),
1506                              nvl(blind_name_j, study_num_j),
1507                              nvl(blind_name, study_num),
1508                              nvl(blind_name_j, study_num_j),
1509                              nvl(blind_name, study_num),
1510                              nvl(blind_name_j, study_num_j)
1511                          INTO
1512                              v_case_product(v_index).product_name,
1513                              v_case_product(v_index).product_name_j,
1514                              v_case_product(v_index).generic_name,
1515                              v_case_product(v_index).generic_name_j,
1516                              v_case_product(v_index).prod_coded,
1517                              v_case_product(v_index).prod_coded_j
1518                          FROM
1519                              tcase_study
1520                          WHERE
1521                              case_id = pi_tcase_id;
1522  
1523                      ELSIF v_code_broken IN ( 1, 2, 3 ) THEN--blind broken
1524  
1525                          v_case_product(v_index).product_id := NULL;
1526                          v_case_product(v_index).pat_exposure := l_product_id;
1527                          v_case_product(v_index).prod_reptd := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1528  
1529                          SELECT
1530                              nvl(blind_name, study_num),
1531                              nvl(blind_name_j, study_num_j),
1532                              nvl(blind_name, study_num),
1533                              nvl(blind_name_j, study_num_j),
1534                              nvl(blind_name, study_num),
1535                              nvl(blind_name_j, study_num_j)
1536                          INTO
1537                              v_case_product(v_index).product_name,
1538                              v_case_product(v_index).product_name_j,
1539                              v_case_product(v_index).generic_name,
1540                              v_case_product(v_index).generic_name_j,
1541                              v_case_product(v_index).prod_coded,
1542                              v_case_product(v_index).prod_coded_j
1543                          FROM
1544                              tcase_study
1545                          WHERE
1546                              case_id = pi_tcase_id;
1547  
1548                      ELSIF v_code_broken = 4 THEN--OPEN LABEL study case
1549  
1550                          v_case_product(v_index).product_id := NULL;
1551                          v_case_product(v_index).pat_exposure := l_product_id;
1552                          v_case_product(v_index).prod_reptd := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1553  
1554                          SELECT
1555                              prod_name,
1556                              prod_name_j,
1557                              prod_generic_name,
1558                              prod_generic_name_j,
1559                              prod_name,
1560                              prod_name_j,
1561                              family_id,
1562                              manufacturer_id,
1563                              prod_generic_name
1564                          INTO
1565                              v_case_product(v_index).product_name,
1566                              v_case_product(v_index).product_name_j,
1567                              v_case_product(v_index).generic_name,
1568                              v_case_product(v_index).generic_name_j,
1569                              v_case_product(v_index).prod_coded,
1570                              v_case_product(v_index).prod_coded_j,
1571                              v_case_product(v_index).family_id,
1572                              v_case_product(v_index).manufacturer_id,
1573                              v_case_product(v_index).generic_name
1574                          FROM
1575                              tlm_product
1576                          WHERE
1577                                  product_id = l_product_id
1578                              AND enterprise_id = pkg_mg_util.f_mg_key_val('Enterprise Id');
1579  
1580                      END IF;
1581  
1582                  ELSE --NON_STUDY_COMAPNY PRIDUCT
1583  
1584                      v_case_product(v_index).product_id := l_product_id;
1585                      v_case_product(v_index).pat_exposure := 0;
1586                      v_case_product(v_index).prod_reptd := nvl(v_row.medicinalproduct, v_row.medicinalproduct);
1587  
1588                      SELECT
1589                          prod_generic_name,
1590                          prod_generic_name_j,
1591                          prod_name,
1592                          prod_name_j,
1593                          family_id,
1594                          manufacturer_id,
1595                          prod_generic_name
1596                      INTO
1597                          v_case_product(v_index).generic_name,
1598                          v_case_product(v_index).generic_name_j,
1599                          v_case_product(v_index).prod_coded,
1600                          v_case_product(v_index).prod_coded_j,
1601                          v_case_product(v_index).family_id,
1602                          v_case_product(v_index).manufacturer_id,
1603                          v_case_product(v_index).generic_name
1604                      FROM
1605                          tlm_product
1606                      WHERE
1607                              product_id = l_product_id
1608                          AND enterprise_id = pkg_mg_util.f_mg_key_val('Enterprise Id');
1609  
1610                      /*PRODUCT LICENSE ID*/
1611                      IF v_case_product(v_index).prod_lic_id IS NOT NULL THEN
1612                          SELECT DISTINCT 
1613                              trade_name,
1614                              trade_name_j
1615                          INTO
1616                              v_trade_name,
1617                              v_trade_name_j
1618                          FROM
1619                                    tlm_license tll
1620                          WHERE
1621                              tll.license_id = v_case_product(v_index).prod_lic_id
1622                              and tll.deleted is null;
1623  
1624                      END IF;
1625  
1626                      v_case_product(v_index).product_name := nvl(
1627                          nvl(v_trade_name,
1628                              v_case_product(v_index).prod_coded),
1629                          v_case_product(v_index).prod_reptd
1630                      );
1631  
1632                      v_case_product(v_index).product_name_j := nvl(
1633                          nvl(v_trade_name_j,
1634                              v_case_product(v_index).prod_coded_j),
1635                          v_case_product(v_index).prod_reptd_j
1636                      );
1637  
1638                  END IF;
1639              ELSE  --NON COMPANY & NON STUDY PRODUCT--
1640                  v_case_product(v_index).selected_view := 7;
1641                  v_case_product(v_index).product_id := NULL;
1642                  v_case_product(v_index).pat_exposure := 0;
1643                  v_case_product(v_index).product_name := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1644  
1645                  v_case_product(v_index).product_name_j := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1646  
1647                  v_case_product(v_index).generic_name := nvl(v_generic_name, v_row.medicinalproduct);
1648                  v_case_product(v_index).generic_name_j := nvl(v_generic_name, v_row.medicinalproduct);
1649                  v_case_product(v_index).prod_reptd := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1650  
1651                  v_case_product(v_index).prod_coded := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1652  
1653                  v_case_product(v_index).prod_coded_j := nvl(v_row.suspect_drug_name, v_row.medicinalproduct);
1654  
1655              END IF;
1656  
1657              v_case_product(v_index).country_id := pkg_mg_util.f_mg_codelist_code('E2B', 'Countries', v_row.obtaindrugcountry);
1658  
1659              v_case_product(v_index).vaers_block_id := 1;
1660              v_case_product(v_index).notes := v_row.drugadditional;
1661              v_case_product(v_index).primary_event := 1;--check with sir.
1662              v_case_product(v_index).auth_number := v_row.drugauthorizationnumb;
1663   v_case_product(v_index).mkt_auth_holder := case when v_row.drugauthorizationholder is null
1664                                           then null
1665                                           else pkg_mg_util.f_mg_key_val('MKT_AUTH_HOLDER') END;--main issue
1666              v_case_product(v_index).views_available := pkg_mg_util.f_mg_views_available(l_product_id);
1667              pkg_mg_util.p_insert_seq_mapping('S_DRUG',
1668                                               'CASE_PRODUCT',
1669                                               'DRUG_SEQ_NUM',
1670                                               'SEQ_NUM',
1671                                               v_row.drug_seq_num,
1672                                               v_case_product(v_index).seq_num);
1673  
1674              pkg_mg_util.p_insert_seq_mapping('S_CASEPRODUCTLEVEL',
1675                                               'CASE_PRODUCT',
1676                                               'PROD_SEQ_NUM',
1677                                               'SEQ_NUM',
1678                                               v_row.prod_seq_num,
