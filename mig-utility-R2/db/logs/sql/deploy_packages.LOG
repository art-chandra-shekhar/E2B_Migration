503  FROM MG_PRODUCT_MAPPING MPM
504  WHERE UPPER(TRIM(NVL(MPM.SUSPECT_DRUG_NAME, MPM.MEDICINAL_PRODUCT))) 
505        = UPPER(TRIM(pi_s_trade_name)) and mpm.PROD_LIC_ID is not null and rownum<=1;
506  
507              EXCEPTION
