467  procedure p_GET_TGT_STUDY_PROD_ID(
468  pi_drug_seq_num NUMBER,
469  pi_study_key NUMBER,
470  pi_cohort_id NUMBER,
471  pi_medicinalproduct IN VARCHAR2,
472  pi_drugdosageform IN VARCHAR2,
473  pi_drugauthorizationNUMB IN VARCHAR2,
474  pi_drugauthorizationcountry IN VARCHAR2,
475  PI_SUSPECT_DRUG_NAME IN VARCHAR2,
476  PI_GENeRIC_NAME IN VARCHAR2,
477  po_TGT_PROD_ID out number,
478  po_TGT_PROD_LIC_ID out number
479  )
480  IS
481  l_tgt_ormulation_id NUMBER;
482  V_MAPPING_TYPE VARCHAR(150);
483  
484  BEGIN
485  po_TGT_PROD_ID:=NULL;
486  po_TGT_PROD_LIC_ID:=NULL;
487  
488  BEGIN
489  
490  SELECT DISTINCT
491     TGT_PRODUCT_ID,TGT_LICENSE_ID,MAPPING
492      INTO 
493      po_TGT_PROD_ID,
494      po_TGT_PROD_LIC_ID,
495      V_MAPPING_TYPE
496  FROM
497      MG_STUDY_PRODUCT_MAPPING
498  WHERE tgt_study_key=pi_study_key
499  and tgt_cohort_id=pi_cohort_id AND
500      upper(trim(suspect_drug_name))
501      || upper(trim(medicinal_product))
502      || upper(trim(dosage_form))
503      || upper(trim(drug_auth_country))
504      || upper(trim(drug_auth_number))
505      || upper(trim(generic_name)) = upper(trim(PI_suspect_drug_name))
506                                     || upper(trim(PI_medicinalproduct))
507                                     || upper(trim(PI_drugdosageform))
508                                     || upper(trim(PI_drugauthorizationcountry))
509                                     || upper(trim(PI_drugauthorizationnumb))
510                                     || upper(trim(PI_GENeRIC_NAME));
511  
512  
513  
514    EXCEPTION
515  
516          WHEN OTHERS  THEN
517  
518              pkg_mg_util.p_mg_log_message(
519                  pi_scase_num    => pkg_mg_util.g_scase_num,
520                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
521                  pi_message_type => 'WARNING',
522                  pi_message      =>upper(trim(PI_suspect_drug_name))
523                                     || upper(trim(PI_medicinalproduct))
524                                     || upper(trim(PI_drugdosageform))
525                                     || upper(trim(PI_drugauthorizationcountry))
526                                     || upper(trim(PI_drugauthorizationnumb))
527                                     || upper(trim(PI_GENeRIC_NAME))||' '||SQLERRM,
528                  pi_thread_id    => NULL,
529                  pi_date_time    => systimestamp
530              );
531              V_MAPPING_TYPE:='Not Mapped';
532              po_tgt_prod_id := NULL;
533              po_tgt_prod_lic_id := NULL;
534  
535          END ;
536  
537             if po_tgt_prod_id IS NULL AND V_MAPPING_TYPE<>'Not Mapped' THEN
538             pkg_mg_util.p_mg_log_message(
539                  pi_scase_num    => pkg_mg_util.g_scase_num,
540                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
541                  pi_message_type => 'USER WARNING',
542                  pi_message      =>upper(trim(PI_suspect_drug_name))
543                                     || upper(trim(PI_medicinalproduct))
544                                     || upper(trim(PI_drugdosageform))
545                                     || upper(trim(PI_drugauthorizationcountry))
546                                     || upper(trim(PI_drugauthorizationnumb))
547                                     || upper(trim(PI_GENeRIC_NAME))||' Mapping Present but target product Id is not mapped ',
548                  pi_thread_id    => NULL,
549                  pi_date_time    => systimestamp
550              );
551              END IF;
552  
553  
554  END p_GET_TGT_STUDY_PROD_ID;
