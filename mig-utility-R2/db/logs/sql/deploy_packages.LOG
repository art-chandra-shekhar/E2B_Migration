712           PROCEDURE p_get_body_sys_event (
713          po_body_sys  OUT VARCHAR2,
714          po_pri_event OUT VARCHAR2
715      ) IS
716      BEGIN
717          SELECT
718              desc_coded,
719              body_sys
720          INTO
721              po_pri_event,
722              po_body_sys
723          FROM
724              tcase_event ce
725          WHERE
726                  ce.case_id = pkg_mg_util.g_tcase_id
727              AND ce.sort_id = 1
728              AND ce.deleted IS NULL;
729  
730      EXCEPTION
731          WHEN no_data_found OR too_many_rows THEN
732              pkg_mg_util.p_mg_log_message(
733                   pi_scase_num    => pkg_mg_util.g_scase_num,
734                  pi_tcase_id     => pkg_mg_util.g_tcase_id,
735                  pi_message_type => 'WARNING',
736                  pi_message      => 'Primary Event Not Found for case',
737                  pi_thread_id    => NULL,
738                  pi_date_time    => systimestamp
739              );
740          WHEN OTHERS THEN
741              raise_application_error(-20003, NULL);
742      END p_get_body_sys_event;
743  END pkg_mg_buss_rules;

