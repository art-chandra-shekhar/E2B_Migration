SQL> /*TRANSFER SCRIPT FROM MG_CL_MASTER TO S_MG_CL_INFO AND T_MG_CL_INFO*/
SQL> SET SERVEROUTPUT ON;
SQL> DECLARE
  2      CURSOR cur IS
  3          SELECT
  4          CL_NAME,
  5          S_CL_TABLE,
  6          S_CL_CODE_COL,
  7          S_CL_DECODE_COL,
  8          S_WHERE_COND,
  9          T_CL_TABLE,
 10          T_CL_CODE_COL,
 11          T_CL_DECODE_COL,
 12          T_WHERE_COND,
 13          ACTIVE,
 14          STATUS,
 15          S_CL_DISPLAY_COL,
 16          T_CL_DISPLAY_COL,
 17          T_CL_E2B_CODE_COL
 18      FROM
 19          mg_cl_master
 20      WHERE S_CL_CODE_COL IS NOT NULL
 21        AND T_CL_CODE_COL IS NOT NULL;
 22  
 23      v_sql    VARCHAR2(4000);
 24      v_code   VARCHAR2(4000);
 25      v_decode VARCHAR2(4000);
 26      r2       SYS_REFCURSOR;
 27      v_disp_s VARCHAR2(100) := NULL;
 28      v_disp_t VARCHAR2(100) := NULL;
 29      vdisp    NUMBER := NULL;
 30      V_E2B_CODE  NUMBER;
 31      V_A2_CODE   VARCHAR2(2000);
 32  BEGIN
 33      DELETE FROM MG_S_CL_INFO;
 34      DELETE FROM MG_T_CL_INFO;
 35  
 36      FOR r1 IN cur LOOP
 37          if r1.T_CL_DISPLAY_COL is null THEN 
 38              V_DISP_t:= '1 display'; 
 39          ELSE 
 40              V_DISP_T:='DISPLAY'; 
 41          END IF;
 42  
 43          /*source_table*/
 44          v_sql := 'SELECT DISTINCT ' || r1.S_CL_CODE_COL || --','||v_disp_s||
 45                   ' FROM ' || r1.S_CL_TABLE || 
 46                   ' WHERE ' || r1.S_CL_DECODE_COL || ' IS NOT NULL';
 47  
 48  
 49          -- Append S_WHERE_COND if present
 50          IF r1.S_WHERE_COND IS NOT NULL THEN
 51              v_sql := v_sql || ' AND ' || r1.S_WHERE_COND;
 52          END IF;
 53  
 54          --dbms_output.put_line('Source SQL');
 55          --dbms_output.put_line(v_sql);
 56  
 57          OPEN r2 FOR v_sql;
 58          LOOP
 59              FETCH r2 INTO v_code; --, vdisp;
 60              EXIT WHEN r2%NOTFOUND;
 61  
 62              --  If Source Code contains Non-Numeric, load in S_CL_DECODE column
 63              IF REGEXP_LIKE(v_code, '[[:alpha:]]') THEN
 64                  INSERT INTO MG_S_CL_INFO(CL_NAME, S_CL_DECODE, S_CL_DISPLAY, CODELIST_TYPE)
 65                  VALUES (r1.CL_NAME, v_code, vdisp, 'E2B');
 66              ELSE
 67              --  If Source Code contains Numbers, load in S_CL_CODE column
 68                  INSERT INTO MG_S_CL_INFO(CL_NAME, S_CL_CODE, S_CL_DISPLAY, CODELIST_TYPE)
 69                  VALUES (r1.CL_NAME, v_code, vdisp, 'E2B');
 70              END IF;
 71  
 72          END LOOP;
 73          CLOSE r2;
 74  
 75          /*target_table*/
 76          v_sql := 'SELECT DISTINCT ' || r1.T_CL_CODE_COL || ', ' || r1.T_CL_DECODE_COL || ',' || v_disp_t ||
 77                   CASE WHEN R1.T_CL_E2B_CODE_COL IS NOT NULL THEN ','|| R1.T_CL_E2B_CODE_COL ELSE ', NULL E2B_CODE' END ||
 78                   CASE WHEN r1.T_CL_TABLE = 'LM_COUNTRIES' THEN ', A2' ELSE ', NULL A2' END ||
 79                   ' FROM ARGUS_APP.' || r1.T_CL_TABLE || 
 80                   ' WHERE ' || r1.T_CL_DECODE_COL || ' IS NOT NULL';
 81  
 82          -- Append T_WHERE_COND if present
 83          IF r1.t_where_cond IS NOT NULL THEN
 84              v_sql := v_sql
 85                       || ' AND '
 86                       || REPLACE(UPPER(r1.t_where_cond),'WHERE');
 87          END IF;
 88  
 89          --dbms_output.put_line('Target SQL');
 90          --dbms_output.put_line(v_sql);
 91  
 92          OPEN r2 FOR v_sql;
 93  
 94          LOOP
 95              FETCH r2 INTO
 96                  v_decode,
 97                  v_code,
 98                  vdisp, 
 99                  V_E2B_CODE,
100                  V_A2_CODE;
101  
102              EXIT WHEN r2%notfound;
103  
104              INSERT INTO mg_t_cl_info (
105                  cl_name,
106                  t_cl_code,
107                  t_cl_decode,
108                  t_cl_display,
109                  t_cl_e2b_code,
110                  t_a2_decode
111              ) VALUES ( r1.cl_name,
112                         v_code,
113                         v_decode,
114                         vdisp, 
115                         V_E2B_CODE,
116                         V_A2_CODE);
117  
118          END LOOP;
119  
120          CLOSE r2;
121  
122          /*updating active and status*/
123          UPDATE mg_cl_master
124          SET
125              active = 1,
126              status = 1
127          WHERE
128              cl_name = r1.cl_name;
129  
130      END LOOP;
131  END;
132  /

